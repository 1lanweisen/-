def compute_metrics(y_true: np.ndarray, y_pred: np.ndarray) -> dict[str, float]:
    acc = accuracy_score(y_true, y_pred)
    macro_f1 = f1_score(y_true, y_pred, labels=list(INT_TO_CLASS.keys()), average="macro", zero_division=0)
    bal_acc = balanced_accuracy_score(y_true, y_pred)
    precision, recall, f1, support = precision_recall_fscore_support(
        y_true,
        y_pred,
        labels=list(INT_TO_CLASS.keys()),
        zero_division=0,
    )
    return {
        "accuracy": float(acc),
        "macro_f1": float(macro_f1),
        "balanced_accuracy": float(bal_acc),
        "satin_precision": float(precision[SATIN_LABEL]),
        "satin_recall": float(recall[SATIN_LABEL]),
        "satin_f1": float(f1[SATIN_LABEL]),
        "satin_support": float(support[SATIN_LABEL]),
    }

def summarize_metric(values: pd.Series) -> tuple[float, float]:
    clean = pd.to_numeric(values, errors="coerce").dropna()
    if len(clean) == 0:
        return float("nan"), float("nan")
    if len(clean) == 1:
        return float(clean.iloc[0]), 0.0
    return float(clean.mean()), float(clean.std(ddof=1))

def group_overlap(left: pd.Series, right: pd.Series) -> set[str]:
