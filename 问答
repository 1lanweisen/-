# 8. Main execution
# Reference: GlazyBench uses fixed train/test evaluation with validity checks for property
# prediction tasks (DOI: 10.48550/arXiv.2605.06641).
# Reference: scikit-learn common pitfalls document recommends pipelines to avoid fitting
# preprocessing on test data: https://scikit-learn.org/stable/common_pitfalls.html
# Modification Reason: 步骤边界/泄漏防护; this script ends after Step 4 tables and does not
# compute Step 5 confusion matrices or PCA projections.
# ======================================================================================

def main() -> None:
    start_time = time.time()
    print("=" * 100)
    print("STEP 4 START")
    print("=" * 100)
    print("step:", STEP_NAME)
    print("time:", utc_now_iso())
    print("python:", sys.version.replace("\n", " "))
    print("platform:", platform.platform())
    print("cwd:", Path.cwd())
    print("INPUT_PARQUET:", INPUT_PARQUET)
    print("OUTPUT_MODEL_COMPARISON:", OUTPUT_MODEL_COMPARISON)

    require_module("pandas", "conda install pandas or pip install pandas")
    require_module("sklearn", "conda install scikit-learn or pip install scikit-learn")
    if importlib.util.find_spec("pyarrow") is None and importlib.util.find_spec("fastparquet") is None:
        raise RuntimeError(
            "No parquet engine found. Install pyarrow first, e.g. conda install pyarrow or pip install pyarrow."
        )
    if XGBClassifier is None:
        raise RuntimeError(
            "xgboost is required because the locked Step 4 model set includes XGB. "
            f"Original import error: {repr(XGB_IMPORT_ERROR)}. Install it before rerunning Step 4."
        )

    ensure_locked_dirs_exist()

    if not INPUT_PARQUET.exists():
        raise FileNotFoundError(f"Step 4 input not found: {INPUT_PARQUET}")
    if not INPUT_T15.exists():
        print("WARNING: T15 gatekeeping table not found. The script will rely on parquet schema and class counts only:", INPUT_T15)

    input_sha256 = sha256_file(INPUT_PARQUET)
    print("input_sha256:", input_sha256)

    # ----------------------------------------------------------------------------------
    # Read and schema-check the Step 3 output.
    # Reference: uploaded Step 3 script exports 03_coverage_ready.parquet and explicitly
    # does not perform model fitting, splitting, CV, SHAP, PCA, or PNG plotting.
    # Modification Reason: 步骤连接; Step 4 starts from the Step 3-ready parquet only.
    # ----------------------------------------------------------------------------------
    df_raw = pd.read_parquet(INPUT_PARQUET)
    required_cols = [ID_COL, TARGET_COL, GROUP_COL, CONE_COL, *FEATURE_COLS]
    fail_if_missing_columns(df_raw, required_cols)

    df = df_raw.copy()
    if "step3_included" in df.columns:
        df = df[df["step3_included"].astype(bool)].copy()

    print("input_rows_raw:", len(df_raw))
    print("input_rows_after_step3_included_filter:", len(df))
    print("input_columns:", len(df.columns))

    unexpected_classes = sorted(set(df[TARGET_COL].dropna().astype(str)) - set(EXPECTED_CLASSES))
    missing_classes = [c for c in EXPECTED_CLASSES if c not in set(df[TARGET_COL].dropna().astype(str))]
    if unexpected_classes:
        raise RuntimeError(f"Unexpected {TARGET_COL} labels for Step 4: {unexpected_classes}")
    if missing_classes:
        raise RuntimeError(f"Missing expected {TARGET_COL} labels for Step 4: {missing_classes}")
    if df[ID_COL].duplicated().any():
        dup_n = int(df[ID_COL].duplicated().sum())
        raise RuntimeError(f"Step 4 requires unique sample_id. Duplicated sample_id rows found: {dup_n}")
    if df[GROUP_COL].isna().any():
        raise RuntimeError("composition_group_id contains missing values; stop before group-aware splitting.")

    for col in FEATURE_COLS:
        df[col] = pd.to_numeric(df[col], errors="coerce")
    if df[FEATURE_COLS].isna().any().any():
        bad_cols = df[FEATURE_COLS].columns[df[FEATURE_COLS].isna().any()].tolist()
        raise RuntimeError("Locked oxide features contain missing/non-numeric values: " + ", ".join(bad_cols))
    if (df[FEATURE_COLS] < 0).any().any():
        bad_cols = df[FEATURE_COLS].columns[(df[FEATURE_COLS] < 0).any()].tolist()
        raise RuntimeError("Locked oxide features contain negative values: " + ", ".join(bad_cols))

    validate_no_leakage_features(df)

    print("surface_type_counts:", df[TARGET_COL].value_counts(dropna=False).to_dict())
    print("composition_group_nunique:", int(df[GROUP_COL].nunique(dropna=True)))

    write_simple_yaml(OUTPUT_C01, {"random_seeds": RANDOM_SEEDS})
    write_simple_yaml(OUTPUT_C02, {"hyperparameter_space": HYPERPARAMETER_SPACE})

    # ----------------------------------------------------------------------------------
    # Select main train/test split from locked seed list.
    # ----------------------------------------------------------------------------------
    train_idx, test_idx, split_info, split_candidates = choose_main_group_split(df)
    train_df = df.iloc[train_idx].copy()
    test_df = df.iloc[test_idx].copy()

    print("\n" + "=" * 100)
    print("MAIN SPLIT SUMMARY")
    print("=" * 100)
    print(pd.DataFrame([split_info]).to_string(index=False))
    print("split_candidates_checked:")
    print(split_candidates.to_string(index=False))

    split_out = build_split_output(df, train_idx, test_idx, split_info)
    write_csv_utf8(split_out, OUTPUT_SPLIT)

    # ----------------------------------------------------------------------------------
    # Prepare modeling arrays using only the locked whitelist.
    # ----------------------------------------------------------------------------------
    X_train = train_df[FEATURE_COLS].copy()
    X_test = test_df[FEATURE_COLS].copy()
    y_train = train_df[TARGET_COL].map(CLASS_TO_INT).to_numpy(dtype=int)
    y_test = test_df[TARGET_COL].map(CLASS_TO_INT).to_numpy(dtype=int)
    groups_train = train_df[GROUP_COL].astype(str).reset_index(drop=True)
    X_train = X_train.reset_index(drop=True)
    X_test = X_test.reset_index(drop=True)

    cv_n_splits = decide_cv_n_splits(train_df)
    print("cv_n_splits:", cv_n_splits)

    baseline = baseline_values(y_train, y_test)
    print("baseline_values:", baseline)

    all_cv_frames = []
    model_rows = []

    for model_name in MODEL_ORDER:
        print("\n" + "=" * 100)
        print("MODEL:", model_name)
        print("=" * 100)
        model_start = time.time()
        cv_df, best = fit_one_model_cv(
            model_name=model_name,
            X_train=X_train,
            y_train=y_train,
            groups_train=groups_train,
            cv_n_splits=cv_n_splits,
            random_state=int(split_info["seed"]),
        )
        all_cv_frames.append(cv_df)
        if best is None:
            model_rows.append(
                {
                    "model_name": model_name,
                    "best_params_json": "",
                    "cv_n_splits": cv_n_splits,
                    "cv_accuracy_mean": np.nan,
                    "cv_accuracy_sd": np.nan,
                    "cv_macro_f1_mean": np.nan,
                    "cv_macro_f1_sd": np.nan,
                    "cv_balanced_accuracy_mean": np.nan,
                    "cv_satin_f1_mean": np.nan,
                    "train_accuracy": np.nan,
                    "train_macro_f1": np.nan,
                    "test_accuracy": np.nan,
                    "test_macro_f1": np.nan,
                    "test_balanced_accuracy": np.nan,
                    "test_satin_precision": np.nan,
                    "test_satin_recall": np.nan,
                    "test_satin_f1": np.nan,
                    "beats_random_baseline": False,
                    "beats_majority_baseline": False,
                    "beats_linear_baseline": False,
                    "selected_as_best": False,
                    "selection_rule": "no_valid_cv_fit",
                    "fit_seconds": round(time.time() - model_start, 3),
                }
            )
            continue

        final_metrics = fit_final_and_evaluate(
            model_name=model_name,
            best_params=best["best_params"],
            X_train=X_train,
            y_train=y_train,
            X_test=X_test,
            y_test=y_test,
            random_state=int(split_info["seed"]),
        )
        row = {
            "model_name": model_name,
            "best_params_json": json_dumps(best["best_params"]),
            "cv_n_splits": cv_n_splits,
            "cv_accuracy_mean": best.get("cv_accuracy_mean", np.nan),
            "cv_accuracy_sd": best.get("cv_accuracy_sd", np.nan),
            "cv_macro_f1_mean": best.get("cv_macro_f1_mean", np.nan),
            "cv_macro_f1_sd": best.get("cv_macro_f1_sd", np.nan),
            "cv_balanced_accuracy_mean": best.get("cv_balanced_accuracy_mean", np.nan),
            "cv_satin_f1_mean": best.get("cv_satin_f1_mean", np.nan),
            **final_metrics,
            "uniform_random_expected_accuracy": baseline["uniform_random_expected_accuracy"],
            "prior_random_expected_accuracy": baseline["prior_random_expected_accuracy"],
            "majority_class_accuracy": baseline["majority_class_accuracy"],
            "majority_class_macro_f1": baseline["majority_class_macro_f1"],
            "random_accuracy_reference": baseline["random_accuracy_reference"],
            "beats_random_baseline": bool(final_metrics["test_accuracy"] > baseline["random_accuracy_reference"]),
            "beats_majority_baseline": bool(final_metrics["test_accuracy"] > baseline["majority_class_accuracy"]),
            "beats_linear_baseline": False,
            "selected_as_best": False,
            "selection_rule": "highest_training_cv_macro_f1_then_cv_accuracy_then_cv_satin_f1; test_set_not_used_for_selection",
            "fit_seconds": round(time.time() - model_start, 3),
        }
        model_rows.append(row)
        print("best_params:", row["best_params_json"])
        print("test_accuracy:", row["test_accuracy"], "test_macro_f1:", row["test_macro_f1"], "test_satin_f1:", row["test_satin_f1"])

