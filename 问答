# Reference: user-provided locked plan, Step 4: use composition_group_id-aware 80/20 split,
# locked random seeds, per-class main-test n>=30, and test-vs-overall class proportion
# deviation <= 2 percentage points.
# Reference: scikit-learn GroupShuffleSplit official docs:
# https://scikit-learn.org/stable/modules/generated/sklearn.model_selection.GroupShuffleSplit.html
# Modification Reason: 泄漏防护; regular train_test_split(stratify=y) cannot guarantee that
# near-duplicate composition_group_id groups stay entirely within train or test.
# ======================================================================================

def choose_main_group_split(df: pd.DataFrame) -> tuple[np.ndarray, np.ndarray, dict[str, Any], pd.DataFrame]:
    overall_props = class_props_from_labels(df[TARGET_COL])
    candidate_rows = []

    for seed_rank, seed in enumerate(RANDOM_SEEDS, start=1):
        splitter = GroupShuffleSplit(n_splits=1, test_size=TEST_SIZE, random_state=seed)
        train_idx, test_idx = next(splitter.split(df[FEATURE_COLS], df[TARGET_COL], groups=df[GROUP_COL]))
        train_df = df.iloc[train_idx]
        test_df = df.iloc[test_idx]

        overlap = group_overlap(train_df[GROUP_COL], test_df[GROUP_COL])
        counts = class_counts_from_labels(test_df[TARGET_COL])
        props = class_props_from_labels(test_df[TARGET_COL])
        deviations_pp = (props - overall_props).abs() * 100.0
        max_dev_pp = float(deviations_pp.max())
        min_test_n = int(counts.min())
        group_leakage_pass = len(overlap) == 0
        class_count_gate_pass = min_test_n >= MAIN_TEST_N_NORMAL_THRESHOLD
        class_prop_gate_pass = max_dev_pp <= (MAX_TEST_CLASS_PROP_DEVIATION_PP + 1e-12)
        selected = bool(group_leakage_pass and class_count_gate_pass and class_prop_gate_pass)

        row = {
            "seed_rank": seed_rank,
            "seed": seed,
            "n_train": int(len(train_df)),
            "n_test": int(len(test_df)),
            "n_train_groups": int(train_df[GROUP_COL].nunique(dropna=True)),
            "n_test_groups": int(test_df[GROUP_COL].nunique(dropna=True)),
            "group_leakage_pass": group_leakage_pass,
            "overlap_group_n": int(len(overlap)),
            "min_test_class_n": min_test_n,
            "class_count_gate_pass": class_count_gate_pass,
            "max_class_prop_deviation_pp": max_dev_pp,
            "class_prop_gate_pass": class_prop_gate_pass,
            "selected": selected,
        }
        for cls in EXPECTED_CLASSES:
            row[f"test_n_{cls}"] = int(counts.loc[cls])
            row[f"test_prop_{cls}"] = float(props.loc[cls])
            row[f"overall_prop_{cls}"] = float(overall_props.loc[cls])
            row[f"test_prop_deviation_pp_{cls}"] = float(deviations_pp.loc[cls])
        candidate_rows.append(row)

        if selected:
            return train_idx, test_idx, row, pd.DataFrame(candidate_rows)

    candidates = pd.DataFrame(candidate_rows)
    raise RuntimeError(
        "No locked random seed produced a valid Step 4 main split. "
        "Review the printed candidate table and stop before modeling.\n"
        + candidates.to_string(index=False)
    )

# ======================================================================================
# 5. Group-aware cross-validation and hyperparameter search
# Reference: user-provided locked plan, Step 4: use StratifiedGroupKFold(n_splits=10),
# downgrade to 5 folds if any class has fewer than 10 available groups, and stop Route B
# if any class has fewer than 5 groups.
# Reference: scikit-learn StratifiedGroupKFold official docs:
# https://scikit-learn.org/stable/modules/generated/sklearn.model_selection.StratifiedGroupKFold.html
# Modification Reason: 泄漏防护/版本兼容; manual CV loops are used instead of opaque helper
# output so every fold can export group-overlap checks, fold class counts, and fit status.
# ======================================================================================

def decide_cv_n_splits(train_df: pd.DataFrame) -> int:
    per_class_group_n = train_df.groupby(TARGET_COL)[GROUP_COL].nunique().reindex(EXPECTED_CLASSES).fillna(0).astype(int)
    min_group_n = int(per_class_group_n.min())
    print("train_group_n_by_class:", per_class_group_n.to_dict())
    if min_group_n >= MIN_CLASS_GROUP_N_FOR_10_FOLD:
        return 10
    if min_group_n >= MIN_CLASS_GROUP_N_FOR_5_FOLD:
        return 5
    raise RuntimeError(
        "Step 4 Route B stopped: at least one class has fewer than 5 training composition_group_id groups. "
        f"Observed per-class group counts: {per_class_group_n.to_dict()}"
    )

def fit_one_model_cv(
    model_name: str,
    X_train: pd.DataFrame,
    y_train: np.ndarray,
    groups_train: pd.Series,
    cv_n_splits: int,
    random_state: int,
) -> tuple[pd.DataFrame, dict[str, Any] | None]:
    cv = StratifiedGroupKFold(n_splits=cv_n_splits, shuffle=True, random_state=random_state)
    base_pipe = make_base_pipeline(model_name, random_state=random_state)
    param_grid = iter_param_grid(HYPERPARAMETER_SPACE[model_name])
    rows: list[dict[str, Any]] = []

    for param_set_id, params in enumerate(param_grid, start=1):
        params_json = json_dumps(params)
        print(f"  {model_name}: param_set {param_set_id}/{len(param_grid)} {params_json}")
        for fold_id, (fold_train_idx, fold_valid_idx) in enumerate(
            cv.split(X_train, y_train, groups=groups_train),
            start=1,
        ):
            fold_train_groups = groups_train.iloc[fold_train_idx]
            fold_valid_groups = groups_train.iloc[fold_valid_idx]
            overlap = group_overlap(fold_train_groups, fold_valid_groups)
            y_tr = y_train[fold_train_idx]
            y_va = y_train[fold_valid_idx]
            row = {
                "model_name": model_name,
                "cv_n_splits": cv_n_splits,
                "fold_id": fold_id,
                "param_set_id": param_set_id,
                "params_json": params_json,
                "n_train": int(len(fold_train_idx)),
                "n_valid": int(len(fold_valid_idx)),
                "n_train_groups": int(pd.Series(fold_train_groups).nunique(dropna=True)),
                "n_valid_groups": int(pd.Series(fold_valid_groups).nunique(dropna=True)),
                "fold_group_overlap_n": int(len(overlap)),
                "fold_group_leakage_pass": bool(len(overlap) == 0),
                "fit_status": "not_started",
                "error_message": "",
            }
            for cls, cls_int in CLASS_TO_INT.items():
                row[f"valid_n_{cls}"] = int(np.sum(y_va == cls_int))

            if overlap:
                row.update({
                    "accuracy": np.nan,
                    "macro_f1": np.nan,
                    "balanced_accuracy": np.nan,
                    "satin_precision": np.nan,
                    "satin_recall": np.nan,
                    "satin_f1": np.nan,
                    "satin_support": np.nan,
                    "fit_status": "failed",
                    "error_message": "group_overlap_detected",
                })
                rows.append(row)
                continue

            try:
                estimator = clone(base_pipe)
                estimator.set_params(**params)
                with warnings.catch_warnings():
                    warnings.simplefilter("ignore")
                    estimator.fit(X_train.iloc[fold_train_idx], y_tr)
                pred = estimator.predict(X_train.iloc[fold_valid_idx])
                metrics = compute_metrics(y_va, pred)
                row.update(metrics)
                row["fit_status"] = "ok"
            except Exception as exc:
                row.update({
                    "accuracy": np.nan,
                    "macro_f1": np.nan,
                    "balanced_accuracy": np.nan,
                    "satin_precision": np.nan,
                    "satin_recall": np.nan,
                    "satin_f1": np.nan,
                    "satin_support": np.nan,
                    "fit_status": "failed",
                    "error_message": repr(exc),
                })
            rows.append(row)

    cv_df = pd.DataFrame(rows)
    ok_df = cv_df[cv_df["fit_status"].eq("ok")].copy()
    if ok_df.empty:
        return cv_df, None

    param_summary = (
        ok_df.groupby(["model_name", "param_set_id", "params_json"], as_index=False)
        .agg(
            n_ok_folds=("fit_status", "size"),
            cv_accuracy_mean=("accuracy", "mean"),
            cv_accuracy_sd=("accuracy", "std"),
            cv_macro_f1_mean=("macro_f1", "mean"),
            cv_macro_f1_sd=("macro_f1", "std"),
            cv_balanced_accuracy_mean=("balanced_accuracy", "mean"),
            cv_satin_f1_mean=("satin_f1", "mean"),
        )
        .sort_values(
            by=["n_ok_folds", "cv_macro_f1_mean", "cv_accuracy_mean", "cv_satin_f1_mean"],
            ascending=[False, False, False, False],
            kind="mergesort",
        )
    )
    # Modification Reason: 泄漏防护; select hyperparameters using training-set CV only.
    # The main test set is not used to select the best hyperparameter combination.
    best = param_summary.iloc[0].to_dict()
    best["best_params"] = json.loads(best["params_json"])
    return cv_df, best

# ======================================================================================
# 6. Final model fit on training set and evaluation on locked test set
# Reference: Cho 2026 retrained final models after cross-validation and evaluated them on
# a held-out test set (DOI: 10.1038/s40494-026-02301-4).
# Modification Reason: 步骤边界; Step 4 exports aggregate model performance only. Detailed
# confusion matrices/PCA coordinates are reserved for Step 5.
# ======================================================================================

def fit_final_and_evaluate(
    model_name: str,
    best_params: dict[str, Any],
    X_train: pd.DataFrame,
    y_train: np.ndarray,
    X_test: pd.DataFrame,
    y_test: np.ndarray,
    random_state: int,
) -> dict[str, Any]:
    estimator = make_base_pipeline(model_name, random_state=random_state)
    estimator.set_params(**best_params)
    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
        estimator.fit(X_train, y_train)
    pred_train = estimator.predict(X_train)
    pred_test = estimator.predict(X_test)
    train_metrics = compute_metrics(y_train, pred_train)
    test_metrics = compute_metrics(y_test, pred_test)
    out = {f"train_{k}": v for k, v in train_metrics.items()}
    out.update({f"test_{k}": v for k, v in test_metrics.items()})
    return out

