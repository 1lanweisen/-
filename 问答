            raise RuntimeError(
                "xgboost is required for XGB reconstruction but could not be imported. "
                f"Original import error: {repr(XGB_IMPORT_ERROR)}"
            )

        return Pipeline(
            steps=[
                ("scaler", StandardScaler()),
                (
                    "clf",
                    XGBClassifier(
                        objective="multi:softprob",
                        num_class=len(EXPECTED_CLASSES),
                        eval_metric="mlogloss",
                        random_state=random_state,
                        seed=random_state,
                        n_jobs=XGB_N_JOBS,
                        tree_method="hist",
                        verbosity=0,
                    ),
                ),
            ]
        )

    raise ValueError(f"Unsupported model_name for this add-on script: {model_name}")

def fit_predict_locked_model(
    model_name: str,
    best_params: dict[str, Any],
    X_train: pd.DataFrame,
    y_train: np.ndarray,
    X_test: pd.DataFrame,
    random_state: int,
) -> np.ndarray:
    estimator = make_base_pipeline(model_name=model_name, random_state=random_state)
    estimator.set_params(**best_params)

    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
        estimator.fit(X_train, y_train)

    return estimator.predict(X_test)

def exact_mcnemar_p_value(b: int, c: int) -> float:
    """
    Exact two-sided McNemar p-value using binomial sign test:
      discordant n = b + c
      X ~ Binomial(n, 0.5)
      p = 2 * P[X <= min(b, c)]
    """
    n = int(b + c)
    k = int(min(b, c))

    if n == 0:
        return float("nan")

    try:
        from scipy.stats import binomtest
        return float(binomtest(k, n=n, p=0.5, alternative="two-sided").pvalue)
    except Exception:
        pass

    # Dependency-free fallback using log-sum-exp.
    log_terms = []
    log_half_n = n * math.log(0.5)

    for i in range(k + 1):
        log_comb = math.lgamma(n + 1) - math.lgamma(i + 1) - math.lgamma(n - i + 1)
        log_terms.append(log_comb + log_half_n)

    max_log = max(log_terms)
    cdf = math.exp(max_log) * sum(math.exp(x - max_log) for x in log_terms)

    return float(min(1.0, 2.0 * cdf))

def chi2_mcnemar_cc(b: int, c: int) -> tuple[float, float]:
    """
    Continuity-corrected McNemar chi-square statistic:
      (|b-c|-1)^2 / (b+c)

    p-value is returned only if scipy is available.
    Exact p-value above is the primary evidence.
    """
    n = int(b + c)

    if n == 0:
        return float("nan"), float("nan")

    stat = (max(abs(b - c) - 1, 0) ** 2) / n

    try:
        from scipy.stats import chi2
        p = float(chi2.sf(stat, df=1))
    except Exception:
        p = float("nan")

    return float(stat), p

