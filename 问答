def build_surface_mapping_table(pd: Any, df: Any) -> Any:
    """
    输出 Surface 映射与排除表。

    锁定规则：
    仅 exact match: Glossy / Matte / Satin。
    其他值全部排除，不做合并。

    修改原因：
    本研究终点是判断 Satin 是否独立或过渡。如果把 Satin - Matte 并入 Satin，
    会把过渡性提前写入标签，导致终点污染。
    """
    s = df["surface_type_raw"].astype(str).str.strip()
    vc = s.value_counts(dropna=False).rename_axis("surface_type_raw").reset_index(name="n_records")

    rows = []
