# 4. PCA coordinates and loadings
# Reference: scikit-learn PCA:
# https://scikit-learn.org/stable/modules/generated/sklearn.decomposition.PCA.html
# Reference: Cho 2026 PCA visualization after model comparison, DOI: 10.1038/s40494-026-02301-4
# Modification Reason: 泄漏防护; StandardScaler and PCA are fit on training rows only,
# then train/test rows are projected into the same fitted space.
# ======================================================================================

def build_pca_sample_rows(df: pd.DataFrame, coords: np.ndarray, split_name: str, pca: PCA, seed: int, run_id: str) -> pd.DataFrame:
    feature_hash = hashlib.sha256("|".join(FEATURE_COLS).encode("utf-8")).hexdigest()
    rows = []
    for idx, row in df.reset_index(drop=True).iterrows():
        rows.append({
            "step_name": STEP_NAME, "run_id": run_id, "primary_seed": seed, "pca_fit_scope": "train_only",
            "row_type": "sample", "sample_id": row[ID_COL], "split": split_name, "surface_type": row[TARGET_COL],
            "composition_group_id": row[GROUP_COL], "cone_stratum": row[CONE_COL],
            "PC1": float(coords[idx, 0]), "PC2": float(coords[idx, 1]),
            "PC1_explained_variance_ratio": float(pca.explained_variance_ratio_[0]),
            "PC2_explained_variance_ratio": float(pca.explained_variance_ratio_[1]),
            "cumulative_explained_variance_ratio_PC1_PC2": float(np.sum(pca.explained_variance_ratio_[:2])),
            "centroid_for_label": "",
            "distance_to_matte_test_centroid": float("nan"),
            "distance_to_satin_test_centroid": float("nan"),
            "distance_to_glossy_test_centroid": float("nan"),
            "feature_set_name": "locked_nine_oxide_features_standardized",
            "feature_set_hash": feature_hash,
            "note": "PCA fitted on training rows only; row projected into locked PCA space",
        })
    return pd.DataFrame(rows)

def build_pca_outputs(train_df: pd.DataFrame, test_df: pd.DataFrame, seed: int, run_id: str) -> tuple[pd.DataFrame, pd.DataFrame]:
    scaler = StandardScaler()
    x_train_scaled = scaler.fit_transform(train_df[FEATURE_COLS].to_numpy(dtype=float))
    x_test_scaled = scaler.transform(test_df[FEATURE_COLS].to_numpy(dtype=float))
    pca = PCA(n_components=2, random_state=seed)
    train_coords = pca.fit_transform(x_train_scaled)
    test_coords = pca.transform(x_test_scaled)

    pca_all = pd.concat([
        build_pca_sample_rows(train_df, train_coords, "train", pca, seed, run_id),
        build_pca_sample_rows(test_df, test_coords, "test", pca, seed, run_id),
    ], ignore_index=True)

    centroids = {}
    centroid_rows = []
    feature_hash = hashlib.sha256("|".join(FEATURE_COLS).encode("utf-8")).hexdigest()
    test_samples = pca_all.loc[pca_all["split"] == "test"].copy()
    for label in EXPECTED_CLASSES:
        sub = test_samples.loc[test_samples["surface_type"] == label, ["PC1", "PC2"]]
        centroid = sub.mean(axis=0).to_numpy(dtype=float) if len(sub) else np.array([np.nan, np.nan])
        centroids[label] = centroid
        centroid_rows.append({
            "step_name": STEP_NAME, "run_id": run_id, "primary_seed": seed, "pca_fit_scope": "train_only",
            "row_type": "test_centroid", "sample_id": "", "split": "test", "surface_type": label,
            "composition_group_id": "", "cone_stratum": "", "PC1": float(centroid[0]), "PC2": float(centroid[1]),
            "PC1_explained_variance_ratio": float(pca.explained_variance_ratio_[0]),
            "PC2_explained_variance_ratio": float(pca.explained_variance_ratio_[1]),
            "cumulative_explained_variance_ratio_PC1_PC2": float(np.sum(pca.explained_variance_ratio_[:2])),
            "centroid_for_label": label,
            "distance_to_matte_test_centroid": float("nan"),
            "distance_to_satin_test_centroid": float("nan"),
            "distance_to_glossy_test_centroid": float("nan"),
            "feature_set_name": "locked_nine_oxide_features_standardized", "feature_set_hash": feature_hash,
            "note": "test-set centroid stored for later geometric audit; no endpoint call in Step 5",
        })

    for label in EXPECTED_CLASSES:
        col = f"distance_to_{label.lower()}_test_centroid"
        pca_all[col] = [euclidean_distance(np.array([r.PC1, r.PC2], dtype=float), centroids[label]) for r in pca_all.itertuples(index=False)]

    pair_rows = []
    for left, right in [("Satin", "Matte"), ("Satin", "Glossy"), ("Matte", "Glossy")]:
        dist = euclidean_distance(centroids[left], centroids[right])
        pair_rows.append({
            "step_name": STEP_NAME, "run_id": run_id, "primary_seed": seed, "pca_fit_scope": "train_only",
            "row_type": "test_centroid_pair_distance", "sample_id": "", "split": "test", "surface_type": f"{left}_to_{right}",
            "composition_group_id": "", "cone_stratum": "", "PC1": float("nan"), "PC2": float("nan"),
            "PC1_explained_variance_ratio": float(pca.explained_variance_ratio_[0]),
            "PC2_explained_variance_ratio": float(pca.explained_variance_ratio_[1]),
            "cumulative_explained_variance_ratio_PC1_PC2": float(np.sum(pca.explained_variance_ratio_[:2])),
            "centroid_for_label": "", "distance_to_matte_test_centroid": float("nan"),
            "distance_to_satin_test_centroid": float("nan"), "distance_to_glossy_test_centroid": float("nan"),
            "feature_set_name": "locked_nine_oxide_features_standardized", "feature_set_hash": feature_hash,
            "note": f"distance_{left}_{right}={dist}; stored for later Step 7 geometric ratio only",
        })

    pca_coords = pd.concat([pca_all, pd.DataFrame(centroid_rows), pd.DataFrame(pair_rows)], ignore_index=True)
    loading_rows = []
    for pc_idx in range(2):
        pc = f"PC{pc_idx + 1}"
        loadings = pca.components_[pc_idx, :]
        ranks = pd.Series(np.abs(loadings), index=FEATURE_COLS).rank(method="first", ascending=False).astype(int)
        for k, feature in enumerate(FEATURE_COLS):
            loading_rows.append({
                "step_name": STEP_NAME, "run_id": run_id, "primary_seed": seed, "pca_fit_scope": "train_only",
                "principal_component": pc, "oxide_feature": feature,
                "loading": float(loadings[k]), "abs_loading": float(abs(loadings[k])),
                "loading_rank_within_pc": int(ranks.loc[feature]),
                "explained_variance_ratio": float(pca.explained_variance_ratio_[pc_idx]),
                "cumulative_explained_variance_ratio_PC1_PC2": float(np.sum(pca.explained_variance_ratio_[:2])),
                "feature_space": "StandardScaler fit on training rows only before PCA",
                "interpretation_guard": "PCA loading sign may flip; linear geometry diagnostic only",
            })
    return pca_coords, pd.DataFrame(loading_rows)

