# 2. Model reconstruction and metrics
# Reference: Cho 2026 compared PCA-LDA, DT, RF, XGB, KNN, and SVM, then interpreted tree
# models with SHAP. DOI: 10.1038/s40494-026-02301-4
# Reference: scikit-learn Pipeline docs:
# https://scikit-learn.org/stable/modules/generated/sklearn.pipeline.Pipeline.html
# Reference: XGBoost sklearn estimator docs:
# https://xgboost.readthedocs.io/en/latest/python/sklearn_estimator.html
# Modification Reason: 步骤连接; mirror Step 4/5 tree model reconstruction and do not
# select a new model or new hyperparameters in Step 6.
# ======================================================================================

def make_tree_pipeline(model_name: str, seed: int) -> Pipeline:
    if model_name == "DT":
        return Pipeline([("scaler", StandardScaler()), ("clf", DecisionTreeClassifier(random_state=seed))])
    if model_name == "RF":
        return Pipeline([("scaler", StandardScaler()), ("clf", RandomForestClassifier(random_state=seed, n_jobs=N_JOBS_TREE))])
    if model_name == "XGB":
        if XGBClassifier is None:
            raise RuntimeError(f"xgboost import failed: {repr(XGB_IMPORT_ERROR)}")
        return Pipeline([
            ("scaler", StandardScaler()),
            ("clf", XGBClassifier(
                objective="multi:softprob",
                num_class=len(EXPECTED_CLASSES),
                eval_metric="mlogloss",
                random_state=seed,
                seed=seed,
                n_jobs=XGB_N_JOBS,
                tree_method="hist",
                verbosity=0,
            )),
        ])
    raise RuntimeError(f"Step 6 TreeExplainer requires DT/RF/XGB, got {model_name}")

def metrics(y_true: np.ndarray, y_pred: np.ndarray) -> dict[str, float]:
    p, r, f, sup = precision_recall_fscore_support(y_true, y_pred, labels=list(INT_TO_CLASS.keys()), zero_division=0)
    return {
        "accuracy": float(accuracy_score(y_true, y_pred)),
        "macro_f1": float(f1_score(y_true, y_pred, labels=list(INT_TO_CLASS.keys()), average="macro", zero_division=0)),
        "balanced_accuracy": float(balanced_accuracy_score(y_true, y_pred)),
        "satin_precision": float(p[SATIN_INT]),
        "satin_recall": float(r[SATIN_INT]),
        "satin_f1": float(f[SATIN_INT]),
        "satin_support": float(sup[SATIN_INT]),
    }

def class_counts(y: pd.Series) -> pd.Series:
    return y.value_counts(dropna=False).reindex(EXPECTED_CLASSES).fillna(0).astype(int)

def class_props(y: pd.Series) -> pd.Series:
    return y.value_counts(normalize=True, dropna=False).reindex(EXPECTED_CLASSES).fillna(0.0).astype(float)

def group_overlap(a: pd.Series, b: pd.Series) -> set[str]:
    return set(a.astype(str)).intersection(set(b.astype(str)))

def load_tree_model_record(mc: pd.DataFrame, t10: pd.DataFrame) -> dict[str, Any]:
    fail_if_missing(mc, ["model_name", "best_params_json", "selected_as_best", "selection_rule"], "04_model_comparison.csv")
    fail_if_missing(t10, ["model_name", "rank", "selected_as_best"], "T10_model_performance_summary.csv")
    selected = mc.loc[bool_series(mc["selected_as_best"]).fillna(False)].copy()
    if len(selected) != 1:
        raise RuntimeError(f"Expected one selected model in 04_model_comparison.csv, got {len(selected)}")

    row = selected.iloc[0]
    selected_model = str(row["model_name"])
    role = "selected_best_tree_model"
    if selected_model not in TREE_MODELS:
        trees = mc.loc[mc["model_name"].astype(str).isin(TREE_MODELS)].copy()
        if trees.empty:
            raise RuntimeError("No DT/RF/XGB model is available for Step 6.")
        sort_cols = [c for c in ["cv_macro_f1_mean", "cv_accuracy_mean", "test_macro_f1"] if c in trees.columns]
        row = trees.sort_values(sort_cols, ascending=[False] * len(sort_cols), kind="mergesort").iloc[0]
        role = "best_tree_model_because_global_best_was_non_tree"

    return {
        "model_name": str(row["model_name"]),
        "best_params": parse_json_dict(row["best_params_json"]),
        "selection_rule": str(row.get("selection_rule", "")),
        "step4_selected_global_best_model": selected_model,
        "explanation_role": role,
        "step4_test_accuracy": safe_float(row.get("test_accuracy", np.nan)),
        "step4_test_macro_f1": safe_float(row.get("test_macro_f1", np.nan)),
        "step4_test_satin_f1": safe_float(row.get("test_satin_f1", np.nan)),
    }

def prepare_data(df_raw: pd.DataFrame, split: pd.DataFrame) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, int]:
    fail_if_missing(df_raw, [ID_COL, TARGET_COL, GROUP_COL, CONE_COL, *FEATURE_COLS], "03_coverage_ready.parquet")
    fail_if_missing(split, [ID_COL, "split", "selected_seed"], "04_train_test_split.csv")

    df = df_raw.copy()
    if "step3_included" in df.columns:
        df = df[df["step3_included"].astype(bool)].copy()

    df[ID_COL] = df[ID_COL].astype(str).str.strip()
    split = split.copy()
    split[ID_COL] = split[ID_COL].astype(str).str.strip()

    validate_feature_whitelist(df)
    for c in FEATURE_COLS:
        df[c] = pd.to_numeric(df[c], errors="coerce")
    if df[FEATURE_COLS].isna().any().any():
        raise RuntimeError("Locked oxide feature matrix contains missing/non-numeric values.")
    if (df[FEATURE_COLS] < 0).any().any():
        raise RuntimeError("Locked oxide feature matrix contains negative values.")

    unexpected = sorted(set(df[TARGET_COL].dropna().astype(str)) - set(EXPECTED_CLASSES))
    if unexpected:
        raise RuntimeError(f"Unexpected target labels: {unexpected}")

    merged = df.merge(split[[ID_COL, "split", "selected_seed"]], on=ID_COL, how="left", validate="one_to_one")
    if merged["split"].isna().any():
        raise RuntimeError(f"Rows missing Step 4 split labels: {int(merged['split'].isna().sum())}")

    seeds = sorted(set(pd.to_numeric(merged["selected_seed"], errors="coerce").dropna().astype(int)))
    if len(seeds) != 1:
        raise RuntimeError(f"Expected one selected_seed, got {seeds}")
    primary_seed = seeds[0]

    train = merged.loc[merged["split"].astype(str).eq("train")].copy()
    test = merged.loc[merged["split"].astype(str).eq("test")].copy()
    ov = group_overlap(train[GROUP_COL], test[GROUP_COL])
    if ov:
        raise RuntimeError(f"Train/test group leakage detected: {len(ov)} overlapping groups.")
    return merged, train, test, primary_seed

def fit_tree(train: pd.DataFrame, model_name: str, params: dict[str, Any], seed: int) -> Pipeline:
    pipe = make_tree_pipeline(model_name, seed)
    if params:
        pipe.set_params(**params)
    y = train[TARGET_COL].astype(str).map(CLASS_TO_INT).to_numpy(dtype=int)
    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
        pipe.fit(train[FEATURE_COLS], y)
    return pipe

def group_split(df: pd.DataFrame, seed: int) -> tuple[pd.DataFrame, pd.DataFrame, dict[str, Any]]:
    # Reference: scikit-learn GroupShuffleSplit docs:
    # https://scikit-learn.org/stable/modules/generated/sklearn.model_selection.GroupShuffleSplit.html
    # Modification Reason: 泄漏防护; composition_group_id cannot cross train/test.
    overall = class_props(df[TARGET_COL])
    splitter = GroupShuffleSplit(n_splits=1, test_size=TEST_SIZE, random_state=seed)
    tr_idx, te_idx = next(splitter.split(df[FEATURE_COLS], df[TARGET_COL], groups=df[GROUP_COL]))
    train, test = df.iloc[tr_idx].copy(), df.iloc[te_idx].copy()
    ov = group_overlap(train[GROUP_COL], test[GROUP_COL])
    counts, props = class_counts(test[TARGET_COL]), class_props(test[TARGET_COL])
    dev = (props - overall).abs() * 100.0
    info = {
        "seed": seed,
        "n_train": int(len(train)),
        "n_test": int(len(test)),
        "n_train_groups": int(train[GROUP_COL].nunique()),
        "n_test_groups": int(test[GROUP_COL].nunique()),
        "overlap_group_n": int(len(ov)),
        "group_leakage_pass": len(ov) == 0,
        "min_test_class_n": int(counts.min()),
        "class_count_gate_pass": int(counts.min()) >= MAIN_TEST_N_NORMAL_THRESHOLD,
        "max_class_prop_deviation_pp": float(dev.max()),
        "class_prop_gate_pass": float(dev.max()) <= MAX_TEST_CLASS_PROP_DEVIATION_PP + 1e-12,
    }
    for cls in EXPECTED_CLASSES:
        info[f"test_n_{cls}"] = int(counts.loc[cls])
        info[f"test_prop_deviation_pp_{cls}"] = float(dev.loc[cls])
    info["split_gate_pass"] = bool(info["group_leakage_pass"] and info["class_count_gate_pass"] and info["class_prop_gate_pass"])
    return train, test, info

# ======================================================================================
# 3. SHAP computation
# Reference: SHAP TreeExplainer official docs:
# https://shap.readthedocs.io/en/latest/generated/shap.TreeExplainer.html
# Reference: Cho 2026 uses SHAP feature importance and SHAP beeswarm plots after
# confusion-matrix/PCA validation. DOI: 10.1038/s40494-026-02301-4
# Modification Reason: 方案一致; DT/RF/XGB use TreeExplainer. PCA-LDA is not treated as
# a SHAP main result; Step 5 PCA loading remains only a linear comparator.
# ======================================================================================

def background_matrix(x_train_scaled: np.ndarray, seed: int) -> tuple[np.ndarray, str]:
    if SHAP_BACKGROUND_MAX_N is None or SHAP_BACKGROUND_MAX_N >= len(x_train_scaled):
        return x_train_scaled, "all_training_rows"
    rng = np.random.default_rng(seed)
    idx = rng.choice(np.arange(len(x_train_scaled)), size=SHAP_BACKGROUND_MAX_N, replace=False)
    return x_train_scaled[idx], f"deterministic_training_subset_n_{SHAP_BACKGROUND_MAX_N}"

def make_explainer(clf: Any, bg: np.ndarray) -> tuple[Any, str]:
    # Modification Reason: 版本兼容; first use training background; if SHAP/xgboost
    # compatibility fails, fall back to model-only TreeExplainer and record this mode.
    try:
        return shap.TreeExplainer(clf, data=bg, model_output="raw"), "train_background_interventional_raw"
    except Exception as exc:
        print("WARNING TreeExplainer with background failed; fallback activated:", repr(exc))
        return shap.TreeExplainer(clf, model_output="raw"), "model_only_tree_path_dependent_fallback"

def normalize_values(explanation: Any, n: int, p: int, k: int) -> np.ndarray:
    values = explanation.values if hasattr(explanation, "values") else explanation
    if isinstance(values, list):
        arrs = [np.asarray(v, dtype=float) for v in values]
        if len(arrs) != k:
            raise RuntimeError(f"SHAP list length {len(arrs)} != n_classes {k}")
        return np.stack(arrs, axis=2)
    arr = np.asarray(values, dtype=float)
    if arr.ndim == 2:
        raise RuntimeError(f"Expected multiclass SHAP values, got 2D shape {arr.shape}")
    if arr.shape == (n, p, k):
        return arr
    if arr.shape == (n, k, p):
        return np.transpose(arr, (0, 2, 1))
    raise RuntimeError(f"Cannot normalize SHAP values shape {arr.shape} to {(n, p, k)}")

def expected_values(explanation: Any, explainer: Any, k: int) -> list[float]:
    base = getattr(explanation, "base_values", None)
    if base is None:
        base = getattr(explainer, "expected_value", None)
    if base is None:
        return [float("nan")] * k
    arr = np.asarray(base, dtype=float)
    if arr.ndim == 0:
        return [float(arr)] * k
    if arr.ndim == 1:
        if len(arr) == k:
            return [float(x) for x in arr]
        return [float(np.nanmean(arr))] * k
    if arr.ndim == 2 and arr.shape[1] == k:
        return [float(np.nanmean(arr[:, i])) for i in range(k)]
    if arr.ndim == 2 and arr.shape[0] == k:
        return [float(np.nanmean(arr[i, :])) for i in range(k)]
    return [float("nan")] * k

def compute_shap(pipe: Pipeline, train: pd.DataFrame, explain: pd.DataFrame, model_name: str, seed: int) -> dict[str, Any]:
    scaler = pipe.named_steps["scaler"]
    clf = pipe.named_steps["clf"]
    x_train_scaled = scaler.transform(train[FEATURE_COLS])
    x_explain_scaled = scaler.transform(explain[FEATURE_COLS])
    bg, bg_note = background_matrix(x_train_scaled, seed)
    explainer, mode = make_explainer(clf, bg)
    with warnings.catch_warnings():
        warnings.simplefilter("ignore")
        try:
            exp = explainer(x_explain_scaled, check_additivity=False)
        except TypeError:
            exp = explainer(x_explain_scaled)
    vals = normalize_values(exp, len(explain), len(FEATURE_COLS), len(EXPECTED_CLASSES))
    pred = pipe.predict(explain[FEATURE_COLS]).astype(int)
    try:
        proba = pipe.predict_proba(explain[FEATURE_COLS])
    except Exception:
        proba = None
    return {
        "values": vals,
        "x_scaled": x_explain_scaled,
        "pred": pred,
        "proba": proba,
        "expected": expected_values(exp, explainer, len(EXPECTED_CLASSES)),
        "model_name": model_name,
        "seed": seed,
        "explainer_type": "TreeExplainer",
        "explainer_mode": mode,
        "background_note": bg_note,
        "n_background": int(len(bg)),
    }

def importance_rows(sh: dict[str, Any], explain: pd.DataFrame, run_id: str, split_name: str, primary: bool) -> pd.DataFrame:
    vals = sh["values"]
    rows = []
    for class_idx, target_class in INT_TO_CLASS.items():
        mean_abs = np.mean(np.abs(vals[:, :, class_idx]), axis=0)
        mean_signed = np.mean(vals[:, :, class_idx], axis=0)
        ranks = pd.Series(mean_abs, index=FEATURE_COLS).rank(method="first", ascending=False).astype(int)
        for j, f in enumerate(FEATURE_COLS):
            s = float(mean_signed[j])
            direction = (
                f"Higher model-input value is associated with higher {target_class} model output margin."
                if s > 0 else
                f"Higher model-input value is associated with lower {target_class} model output margin."
                if s < 0 else
                f"No average signed direction for {target_class} model output margin."
            )
            rows.append({
                "step_name": STEP_NAME, "run_id": run_id, "random_seed": sh["seed"],
                "is_primary_split": bool(primary), "model_name": sh["model_name"],
                "explainer_type": sh["explainer_type"], "explainer_mode": sh["explainer_mode"],
                "background_note": sh["background_note"], "n_background": sh["n_background"],
                "data_split_explained": split_name, "n_explained": len(explain),
                "target_class": target_class, "target_class_index": class_idx,
                "feature": f, "feature_index": j, "mean_abs_shap": float(mean_abs[j]),
                "mean_shap": s, "rank": int(ranks.loc[f]), "included_in_top5": int(ranks.loc[f]) <= 5,
                "direction_text": direction,
                "interpretation_guard": "association_with_model_output_not_causal_effect",
                "model_input_space": "StandardScaler_transformed_oxide_features",
                "raw_feature_space": "normalized_oxide_wt_percent",
                "shap_output_space": "raw_model_margin_or_logit_space",
                "feature_set_hash": feature_hash(),
            })
    macro = np.mean(np.abs(vals), axis=(0, 2))
    macro_signed = np.mean(vals, axis=(0, 2))
    macro_ranks = pd.Series(macro, index=FEATURE_COLS).rank(method="first", ascending=False).astype(int)
    for j, f in enumerate(FEATURE_COLS):
        rows.append({
            "step_name": STEP_NAME, "run_id": run_id, "random_seed": sh["seed"],
            "is_primary_split": bool(primary), "model_name": sh["model_name"],
            "explainer_type": sh["explainer_type"], "explainer_mode": sh["explainer_mode"],
            "background_note": sh["background_note"], "n_background": sh["n_background"],
            "data_split_explained": split_name, "n_explained": len(explain),
            "target_class": "overall_macro", "target_class_index": -1,
            "feature": f, "feature_index": j, "mean_abs_shap": float(macro[j]),
            "mean_shap": float(macro_signed[j]), "rank": int(macro_ranks.loc[f]),
            "included_in_top5": int(macro_ranks.loc[f]) <= 5,
            "direction_text": "Overall macro SHAP importance averaged across Matte/Satin/Glossy model outputs.",
            "interpretation_guard": "association_with_model_output_not_causal_effect",
            "model_input_space": "StandardScaler_transformed_oxide_features",
            "raw_feature_space": "normalized_oxide_wt_percent",
            "shap_output_space": "raw_model_margin_or_logit_space",
            "feature_set_hash": feature_hash(),
        })
    return pd.DataFrame(rows)

def beeswarm_rows(sh: dict[str, Any], explain: pd.DataFrame, run_id: str, split_name: str) -> pd.DataFrame:
    vals, xs, pred, proba, ev = sh["values"], sh["x_scaled"], sh["pred"], sh["proba"], sh["expected"]
    raw = explain[FEATURE_COLS].to_numpy(dtype=float)
    true_int = explain[TARGET_COL].astype(str).map(CLASS_TO_INT).to_numpy(dtype=int)
    ids = explain[ID_COL].astype(str).to_numpy()
    rows = []
    for i in range(len(explain)):
        for class_idx, target in INT_TO_CLASS.items():
            prob = float(proba[i, class_idx]) if proba is not None and proba.ndim == 2 else float("nan")
            for j, f in enumerate(FEATURE_COLS):
                rows.append({
                    "step_name": STEP_NAME, "run_id": run_id, "random_seed": sh["seed"],
                    "model_name": sh["model_name"], "explainer_type": sh["explainer_type"],
                    "explainer_mode": sh["explainer_mode"], "background_note": sh["background_note"],
                    "sample_id": ids[i], "split": split_name, "true_label": INT_TO_CLASS[int(true_int[i])],
                    "predicted_label": INT_TO_CLASS[int(pred[i])], "target_class": target,
                    "target_class_index": class_idx, "predicted_probability_for_target_class": prob,
                    "feature": f, "feature_index": j, "feature_value_raw": float(raw[i, j]),
                    "feature_value_model_input_scaled": float(xs[i, j]), "shap_value": float(vals[i, j, class_idx]),
                    "expected_value": float(ev[class_idx]),
                    "interpretation_guard": "sample_level_association_with_model_output_not_causal_effect",
                })
    return pd.DataFrame(rows)

# ======================================================================================
# 4. Stability and output tables
# Reference: locked plan Step 6 requires top-5 features across 10 fixed seeds and J5.
# Modification Reason: 可审计性; report overlap/5 as the plan's "平均重合比例", and also
# Jaccard@5 as an auxiliary stability index.
# ======================================================================================

def top5(imp: pd.DataFrame, target: str) -> list[str]:
    sub = imp.loc[imp["target_class"].astype(str).eq(target)].copy()
    return sub.sort_values(["rank", "feature"], kind="mergesort").head(5)["feature"].astype(str).tolist()

def ov_stats(a: list[str], b: list[str]) -> dict[str, Any]:
    sa, sb = set(a), set(b)
    inter, union = sa.intersection(sb), sa.union(sb)
    return {
        "top5_overlap_n": len(inter),
        "j5_overlap_ratio": len(inter) / 5.0,
        "j5_jaccard": len(inter) / len(union) if union else float("nan"),
        "overlap_features": ";".join(sorted(inter)),
    }

def build_stability(df: pd.DataFrame, seeds: list[int], model_name: str, params: dict[str, Any], primary_seed: int, primary_top5: dict[str, list[str]]) -> tuple[pd.DataFrame, pd.DataFrame]:
    stab_rows, imp_all = [], []
    for seed in seeds:
        run_id = f"step6_stability_seed_{seed}_{model_name}"
        try:
            tr, te, info = group_split(df, seed)
            if not info["split_gate_pass"]:
                stab_rows.append({
                    "step_name": STEP_NAME, "row_type": "seed_stability", "run_id": run_id,
                    "random_seed": seed, "model_name": model_name, "target_class": "",
                    "status": "split_gate_failed", "top5_features": "", "primary_top5_features": "",
                    "top5_overlap_n": np.nan, "j5_overlap_ratio": np.nan, "j5_jaccard": np.nan,
                    "overlap_features": "", "satin_recall": np.nan, "satin_precision": np.nan,
                    "satin_f1": np.nan, "macro_f1": np.nan, "accuracy": np.nan,
                    "split_info_json": json_dumps(info),
                    "stability_note": "Seed split failed Step 4-style gate.",
                })
                continue
            pipe = fit_tree(tr, model_name, params, seed)
            y = te[TARGET_COL].astype(str).map(CLASS_TO_INT).to_numpy(dtype=int)
            pred = pipe.predict(te[FEATURE_COLS]).astype(int)
            met = metrics(y, pred)
            sh = compute_shap(pipe, tr, te, model_name, seed)
            imp = importance_rows(sh, te, run_id, "test", primary=(seed == primary_seed))
            imp_all.append(imp)
            for target, base_top5 in primary_top5.items():
                current_top5 = top5(imp, target)
                stab_rows.append({
                    "step_name": STEP_NAME, "row_type": "seed_stability", "run_id": run_id,
                    "random_seed": seed, "model_name": model_name, "target_class": target,
                    "status": "ok", "top5_features": ";".join(current_top5),
                    "primary_top5_features": ";".join(base_top5), **ov_stats(current_top5, base_top5),
                    "satin_recall": met["satin_recall"], "satin_precision": met["satin_precision"],
                    "satin_f1": met["satin_f1"], "macro_f1": met["macro_f1"], "accuracy": met["accuracy"],
                    "split_info_json": json_dumps(info),
                    "stability_note": "Top-5 compared with primary split top-5 under fixed tree model and fixed hyperparameters.",
                })
            print(f"seed={seed} stability=ok acc={met['accuracy']:.6f} macro_f1={met['macro_f1']:.6f} satin_recall={met['satin_recall']:.6f}")
        except Exception as exc:
            stab_rows.append({
                "step_name": STEP_NAME, "row_type": "seed_stability", "run_id": run_id,
                "random_seed": seed, "model_name": model_name, "target_class": "",
                "status": "failed", "top5_features": "", "primary_top5_features": "",
                "top5_overlap_n": np.nan, "j5_overlap_ratio": np.nan, "j5_jaccard": np.nan,
                "overlap_features": "", "satin_recall": np.nan, "satin_precision": np.nan,
                "satin_f1": np.nan, "macro_f1": np.nan, "accuracy": np.nan,
                "split_info_json": "", "stability_note": repr(exc),
            })
            print(f"WARNING seed={seed} stability failed: {repr(exc)}")

    stab = pd.DataFrame(stab_rows)
    aggs = []
    ok = stab.loc[stab["status"].eq("ok")].copy()
    for target in sorted(ok["target_class"].dropna().unique()):
        sub = ok.loc[ok["target_class"].eq(target)].copy()
        rec = pd.to_numeric(sub["satin_recall"], errors="coerce").dropna()
        iqr = float(np.percentile(rec, 75) - np.percentile(rec, 25)) if len(rec) else float("nan")
        aggs.append({
            "step_name": STEP_NAME, "row_type": "aggregate_stability",
            "run_id": f"step6_stability_aggregate_{target}_{model_name}",
            "random_seed": -1, "model_name": model_name, "target_class": target,
            "status": "ok" if len(sub) == len(seeds) else "partial",
            "top5_features": "", "primary_top5_features": ";".join(primary_top5.get(target, [])),
            "top5_overlap_n": float(pd.to_numeric(sub["top5_overlap_n"], errors="coerce").mean()),
            "j5_overlap_ratio": float(pd.to_numeric(sub["j5_overlap_ratio"], errors="coerce").mean()),
            "j5_jaccard": float(pd.to_numeric(sub["j5_jaccard"], errors="coerce").mean()),
            "overlap_features": "", "satin_recall": float(rec.median()) if len(rec) else float("nan"),
            "satin_precision": float(pd.to_numeric(sub["satin_precision"], errors="coerce").median()),
            "satin_f1": float(pd.to_numeric(sub["satin_f1"], errors="coerce").median()),
            "macro_f1": float(pd.to_numeric(sub["macro_f1"], errors="coerce").median()),
            "accuracy": float(pd.to_numeric(sub["accuracy"], errors="coerce").median()),
            "split_info_json": json_dumps({"n_ok_seed_rows": int(len(sub)), "n_locked_seeds": int(len(seeds))}),
            "stability_note": f"IQR_satin_recall={iqr:.6f}; Step 7 should use target_class='Satin' j5_overlap_ratio.",
        })
    if aggs:
        stab = pd.concat([stab, pd.DataFrame(aggs)], ignore_index=True)
    imp_df = pd.concat(imp_all, ignore_index=True) if imp_all else pd.DataFrame()
    return stab, imp_df

def build_t13(primary_imp: pd.DataFrame, t12: pd.DataFrame) -> pd.DataFrame:
