    if bad:
        raise RuntimeError("Leakage-risk columns in FEATURE_COLS: " + ", ".join(bad))
    risky = [c for c in df.columns if c in LEAKAGE_RISK_EXACT or any(c.startswith(p) for p in LEAKAGE_RISK_PREFIXES)]
    print("feature_whitelist:", FEATURE_COLS)
    print("leakage_risk_columns_present_but_excluded:", risky)

