def build_confusion_long(y_true: np.ndarray, y_pred: np.ndarray, split_name: str, run_id: str, best_model_name: str, seed: int, selection_rule: str) -> pd.DataFrame:
    cm_count = confusion_matrix(y_true, y_pred, labels=EXPECTED_CLASSES)
    cm_norm = confusion_matrix(y_true, y_pred, labels=EXPECTED_CLASSES, normalize="true")
    rows = []
    for i, true_label in enumerate(EXPECTED_CLASSES):
        row_total = int(cm_count[i, :].sum())
        for j, pred_label in enumerate(EXPECTED_CLASSES):
            value = float(cm_norm[i, j]) if row_total > 0 else float("nan")
            rows.append({
                "step_name": STEP_NAME, "run_id": run_id, "primary_seed": seed,
                "best_model_name": best_model_name, "best_model_selection_rule": selection_rule,
                "split": split_name, "matrix_type": "count_and_row_normalized",
                "true_label": true_label, "predicted_label": pred_label, "n": int(cm_count[i, j]),
                "row_total": row_total, "value": value, "percent": value * 100.0 if not math.isnan(value) else float("nan"),
                "class_order": json.dumps(EXPECTED_CLASSES, ensure_ascii=False),
                "source_split_file": str(INPUT_SPLIT), "source_feature_file": str(INPUT_PARQUET),
            })
    return pd.DataFrame(rows)

def build_confusion_summary(y_true: np.ndarray, y_pred: np.ndarray, split_name: str, run_id: str, best_model_name: str, seed: int) -> pd.DataFrame:
    precision, recall, f1, support = precision_recall_fscore_support(y_true, y_pred, labels=EXPECTED_CLASSES, zero_division=0)
    cm = confusion_matrix(y_true, y_pred, labels=EXPECTED_CLASSES)
    rows = []
    for i, label in enumerate(EXPECTED_CLASSES):
        row_total = int(cm[i, :].sum())
        correct_n = int(cm[i, i])
        mis_n = row_total - correct_n
        dest_counts = {f"misclassified_to_{lab.lower()}_n": int(cm[i, j]) if j != i else 0 for j, lab in enumerate(EXPECTED_CLASSES)}
        dest_pct = {f"misclassified_to_{lab.lower()}_pct": (float(cm[i, j]) / mis_n * 100.0) if (j != i and mis_n > 0) else 0.0 for j, lab in enumerate(EXPECTED_CLASSES)}
        off_diag = [(EXPECTED_CLASSES[j], int(cm[i, j])) for j in range(len(EXPECTED_CLASSES)) if j != i]
        dominant = max(off_diag, key=lambda x: x[1])[0] if off_diag and max(v for _, v in off_diag) > 0 else ""
        rows.append({
            "step_name": STEP_NAME, "run_id": run_id, "primary_seed": seed,
            "best_model_name": best_model_name, "split": split_name, "class_label": label,
            "support": int(support[i]), "precision": float(precision[i]), "recall": float(recall[i]), "f1": float(f1[i]),
            "overall_accuracy": float(accuracy_score(y_true, y_pred)),
            "macro_f1": float(f1_score(y_true, y_pred, labels=EXPECTED_CLASSES, average="macro", zero_division=0)),
            "balanced_accuracy": float(balanced_accuracy_score(y_true, y_pred)),
            "correct_n": correct_n, "misclassified_n": mis_n,
            **dest_counts, **dest_pct,
            "dominant_error_target": dominant,
            "satin_row_flag": bool(label == SATIN_LABEL),
            "interpretation_guard": "diagnostic_only_no_endpoint_call",
        })
    return pd.DataFrame(rows)

