#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
STEP 3: 类别覆盖、可用性诊断与样本量门槛

Purpose
-------
This script executes only Step 3 of the locked research plan:
1) read the Step 2 cleaned and leakage-grouped feature matrix;
2) diagnose Matte/Satin/Glossy class coverage and composition_group_id coverage;
3) summarize core oxide distributions by surface class;
4) apply the pre-locked sample-count and group-count gates;
5) export Step 3 analysis tables and a Step 3-ready parquet file.

No model fitting, train/test split, cross-validation, SHAP, PCA, or PNG plotting is performed here.
PNG plotting is intentionally deferred because the user's global execution rule says:
"先生成分析数据，最后一步才允许绘图".

References embedded in comments use DOI/URL-level sources only.
"""

from __future__ import annotations

import hashlib
import importlib.util
import platform
import sys
from datetime import datetime, timezone
from pathlib import Path
from typing import Iterable

import numpy as np
import pandas as pd

# ======================================================================================
# 0. Locked paths and constants
# Reference: user-provided locked plan, Step 3.
# Modification Reason: 路径环境差异; the plan gives Windows paths, while this script is
# executed by python3 inside WSL, so the locked D: root is represented as /mnt/d.
# ======================================================================================

STEP_NAME = "Step 3：类别覆盖、可用性诊断与样本量门槛"

RESULT_DIR = Path("/mnt/d/其他-小论文/陈洪杰/glazy/方案二/结果")
DATA_INTERIM_DIR = RESULT_DIR / "data_interim"
TABLES_DIR = RESULT_DIR / "tables"
FIGURES_DIR = RESULT_DIR / "figures"

INPUT_PARQUET = DATA_INTERIM_DIR / "02_qc_grouped_feature_matrix.parquet"
OUTPUT_PARQUET = DATA_INTERIM_DIR / "03_coverage_ready.parquet"

OUTPUT_T07 = TABLES_DIR / "T07_surface_category_distribution.csv"
OUTPUT_T08 = TABLES_DIR / "T08_oxide_distribution_by_surface.csv"
OUTPUT_T15 = TABLES_DIR / "T15_class_count_gatekeeping.csv"
OUTPUT_F03_DATA = FIGURES_DIR / "F03_surface_category_distribution_data.csv"

EXPECTED_CLASSES = ["Matte", "Satin", "Glossy"]
CORE_OXIDES = ["SiO2", "Al2O3", "Fe2O3", "MgO", "CaO", "Na2O", "K2O", "TiO2", "ZnO"]

MIN_CLASS_N_FOR_MODEL_ENTRY = 50
MIN_CLASS_GROUP_N_FOR_MODEL_ENTRY = 5
MAIN_TEST_N_NORMAL_THRESHOLD = 30
MAIN_TEST_N_CONSERVATIVE_LOWER = 20
EXPECTED_TEST_FRACTION_AUDIT_ONLY = 0.20

GENERATE_PNG = False

# ======================================================================================
# 1. Utility functions
# Reference: pandas official I/O API docs:
# https://pandas.pydata.org/docs/reference/api/pandas.read_parquet.html
# https://pandas.pydata.org/docs/reference/api/pandas.DataFrame.to_parquet.html
# https://pandas.pydata.org/docs/reference/api/pandas.DataFrame.to_csv.html
# Modification Reason: 版本兼容; dependency checks are explicit so that a missing parquet
# engine fails before any partial output is written.
# ======================================================================================

def utc_now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()

def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def require_module(module_name: str, install_hint: str) -> None:
    if importlib.util.find_spec(module_name) is None:
        raise RuntimeError(
            f"Missing required module: {module_name}. "
            f"Install/activate it before running this step. Hint: {install_hint}"
        )

def ensure_locked_dirs_exist() -> None:
    for d in [DATA_INTERIM_DIR, TABLES_DIR, FIGURES_DIR]:
        d.mkdir(parents=True, exist_ok=True)

def write_csv_utf8(df: pd.DataFrame, path: Path) -> None:
    df.to_csv(path, index=False, encoding="utf-8-sig", lineterminator="\n")

def fail_if_missing_columns(df: pd.DataFrame, required_cols: Iterable[str]) -> None:
    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise RuntimeError(
            "Input parquet is missing required columns for Step 3: "
            + ", ".join(missing)
        )

def status_from_expected_test_n(expected_test_n_floor: int) -> tuple[str, str]:
    if expected_test_n_floor >= MAIN_TEST_N_NORMAL_THRESHOLD:
        return "pass", "normal"
    if MAIN_TEST_N_CONSERVATIVE_LOWER <= expected_test_n_floor < MAIN_TEST_N_NORMAL_THRESHOLD:
        return "warning", "conservative"
    return "fail", "no_endpoint"

def gate_result(observed: float, threshold: float) -> str:
    return "pass" if observed >= threshold else "fail"

# ======================================================================================
# 2. Start log and dependency validation
# Reference: GlazyBench used a standardized benchmark pipeline and enforced validity
# checks before evaluation (DOI: 10.48550/arXiv.2605.06641).
# Modification Reason: 版本兼容; this script validates local Python/parquet dependencies
# before reading the Step 2 matrix, because WSL and RStudio will later exchange parquet/CSV.
# ======================================================================================

print("=" * 100)
print("STEP 3 START")
print("=" * 100)
print("step:", STEP_NAME)
print("time:", utc_now_iso())
print("python:", sys.version.replace("\n", " "))
print("platform:", platform.platform())
print("cwd:", Path.cwd())
print("INPUT_PARQUET:", INPUT_PARQUET)
print("OUTPUT_PARQUET:", OUTPUT_PARQUET)

require_module("pandas", "conda install pandas or pip install pandas")
if importlib.util.find_spec("pyarrow") is None and importlib.util.find_spec("fastparquet") is None:
    raise RuntimeError(
        "No parquet engine found. Install pyarrow first, e.g. conda install pyarrow "
        "or pip install pyarrow, then rerun Step 3."
    )

ensure_locked_dirs_exist()

if not INPUT_PARQUET.exists():
    raise FileNotFoundError(f"Step 3 input not found: {INPUT_PARQUET}")

input_sha256 = sha256_file(INPUT_PARQUET)
print("input_sha256:", input_sha256)

# ======================================================================================
# 3. Read Step 2 feature matrix and validate schema
# Reference: Cho 2026 first used a curated and normalized composition matrix before
# downstream validation/modeling (DOI: 10.1038/s40494-026-02301-4).
# Reference: GlazyBench treated surface labels as enumerated task labels including
# Glossy, Matte, and Satin (DOI: 10.48550/arXiv.2605.06641).
# Modification Reason: 字段不一致; the uploaded Step 2 matrix uses `surface_type`
# as the locked three-class endpoint column, not a generic `surface_class` name.
# ======================================================================================

df_raw = pd.read_parquet(INPUT_PARQUET)

required_columns = [
    "sample_id",
    "surface_type",
    "cone_stratum",
    "composition_group_id",
    "include_step2",
    *CORE_OXIDES,
]
fail_if_missing_columns(df_raw, required_columns)

print("\n" + "=" * 100)
print("INPUT SUMMARY")
print("=" * 100)
print("input_rows:", len(df_raw))
print("input_columns:", len(df_raw.columns))
print("surface_type_counts_raw:", df_raw["surface_type"].value_counts(dropna=False).to_dict())

df = df_raw.copy()

df = df[df["include_step2"].astype(bool)].copy()

unexpected_classes = sorted(set(df["surface_type"].dropna().astype(str)) - set(EXPECTED_CLASSES))
missing_classes = [c for c in EXPECTED_CLASSES if c not in set(df["surface_type"].dropna().astype(str))]
if unexpected_classes:
    raise RuntimeError(
        "Step 3 only accepts strict Matte/Satin/Glossy labels. "
        f"Unexpected labels found after include_step2 filter: {unexpected_classes}"
    )
if missing_classes:
    raise RuntimeError(
        "Step 3 requires all three strict surface classes. "
        f"Missing classes after include_step2 filter: {missing_classes}"
    )

for oxide in CORE_OXIDES:
    df[oxide] = pd.to_numeric(df[oxide], errors="coerce")

oxide_missing = df[CORE_OXIDES].isna().any(axis=1)
oxide_negative = (df[CORE_OXIDES] < 0).any(axis=1)
if bool(oxide_missing.any()) or bool(oxide_negative.any()):
    bad = int((oxide_missing | oxide_negative).sum())
    raise RuntimeError(
        f"Step 3 found {bad} rows with missing or negative locked core oxides. "
        "This should have been resolved in Step 2; stop before coverage diagnosis."
    )

print("rows_after_include_step2_filter:", len(df))
print("surface_type_counts_step3:", df["surface_type"].value_counts(dropna=False).to_dict())
print("composition_group_nunique:", int(df["composition_group_id"].nunique(dropna=True)))

# ======================================================================================
# 4. Surface category distribution and group coverage
# Reference: GlazyBench reports task annotation coverage and class distributions before
# model evaluation (DOI: 10.48550/arXiv.2605.06641).
# Modification Reason: 研究问题差异; GlazyBench reports a 9-class surface task, while this
# plan intentionally restricts Y to Matte/Satin/Glossy to test Satin separability.
# ======================================================================================

total_n = int(len(df))
total_group_n = int(df["composition_group_id"].nunique(dropna=True))

dist_rows = []
for cls in EXPECTED_CLASSES:
    part = df[df["surface_type"] == cls]
    n_samples = int(len(part))
    n_groups = int(part["composition_group_id"].nunique(dropna=True))
    total_n_gate = gate_result(n_samples, MIN_CLASS_N_FOR_MODEL_ENTRY)
    group_gate = gate_result(n_groups, MIN_CLASS_GROUP_N_FOR_MODEL_ENTRY)
    fail_reasons = []
    if total_n_gate == "fail":
        fail_reasons.append(f"n_samples_lt_{MIN_CLASS_N_FOR_MODEL_ENTRY}")
    if group_gate == "fail":
        fail_reasons.append(f"composition_group_id_lt_{MIN_CLASS_GROUP_N_FOR_MODEL_ENTRY}")

    dist_rows.append(
        {
            "surface_type": cls,
            "n_samples": n_samples,
            "percent_samples": round(n_samples / total_n * 100.0, 6) if total_n else np.nan,
            "n_composition_groups": n_groups,
            "percent_composition_groups": round(n_groups / total_group_n * 100.0, 6) if total_group_n else np.nan,
            "min_required_n": MIN_CLASS_N_FOR_MODEL_ENTRY,
            "min_required_groups": MIN_CLASS_GROUP_N_FOR_MODEL_ENTRY,
            "gate_pass": (total_n_gate == "pass" and group_gate == "pass"),
            "fail_reason": ";".join(fail_reasons) if fail_reasons else "",
        }
    )

t07 = pd.DataFrame(dist_rows)

# ======================================================================================
# 5. Core oxide distribution by surface class
# Reference: Cho 2026 used oxide wt% composition features for ceramic type classification
# and first described the class-specific dataset before modeling (DOI: 10.1038/s40494-026-02301-4).
# Modification Reason: 字段不一致; Cho 2026 used ten major oxides, whereas the locked plan
# uses nine Glazy oxide fields: SiO2, Al2O3, Fe2O3, MgO, CaO, Na2O, K2O, TiO2, ZnO.
# ======================================================================================

oxide_rows = []
for cls in EXPECTED_CLASSES:
    part = df[df["surface_type"] == cls]
    for oxide in CORE_OXIDES:
        s = pd.to_numeric(part[oxide], errors="coerce").dropna()
        oxide_rows.append(
            {
                "surface_type": cls,
                "oxide": oxide,
                "n_non_missing": int(s.shape[0]),
                "mean": float(s.mean()) if len(s) else np.nan,
                "std": float(s.std(ddof=1)) if len(s) > 1 else np.nan,
                "median": float(s.median()) if len(s) else np.nan,
                "q1": float(s.quantile(0.25)) if len(s) else np.nan,
                "q3": float(s.quantile(0.75)) if len(s) else np.nan,
                "min": float(s.min()) if len(s) else np.nan,
                "max": float(s.max()) if len(s) else np.nan,
            }
        )

t08 = pd.DataFrame(oxide_rows)

# ======================================================================================
# 6. Gatekeeping table for Step 3 -> Step 4 transition
# Reference: user-provided locked plan, Step 3 gate:
# any class n < 50 or composition_group_id < 5 stops three-class modeling; expected
# main-test n is audited against n>=30 / 20-29 / <20 before endpoint interpretation.
# Reference: Cho 2026 used a class-balanced 80/20 internal test split before model
# comparison (DOI: 10.1038/s40494-026-02301-4).
# Modification Reason: 步骤边界; Step 3 does not create the actual 80/20 split. It only
# audits whether a future Step 4 split is likely to meet the pre-locked class-count gate.
# ======================================================================================

gate_rows = []
for _, row in t07.iterrows():
    cls = row["surface_type"]
    n_samples = int(row["n_samples"])
    n_groups = int(row["n_composition_groups"])
    expected_test_n_floor = int(np.floor(n_samples * EXPECTED_TEST_FRACTION_AUDIT_ONLY))
    expected_gate_status, route_a_statement_level = status_from_expected_test_n(expected_test_n_floor)

    gate_rows.append(
        {
            "gate_name": "model_entry_total_n",
            "surface_type": cls,
            "observed_value": n_samples,
            "threshold_value": MIN_CLASS_N_FOR_MODEL_ENTRY,
            "gate_result": gate_result(n_samples, MIN_CLASS_N_FOR_MODEL_ENTRY),
            "action": "continue_three_class" if n_samples >= MIN_CLASS_N_FOR_MODEL_ENTRY else "downgrade_binary_or_descriptive_only",
            "notes": "Locked Step 3 model-entry gate: each class must have at least 50 retained samples.",
        }
    )
    gate_rows.append(
        {
            "gate_name": "model_entry_group_n",
            "surface_type": cls,
            "observed_value": n_groups,
            "threshold_value": MIN_CLASS_GROUP_N_FOR_MODEL_ENTRY,
            "gate_result": gate_result(n_groups, MIN_CLASS_GROUP_N_FOR_MODEL_ENTRY),
            "action": "continue_three_class" if n_groups >= MIN_CLASS_GROUP_N_FOR_MODEL_ENTRY else "downgrade_binary_or_descriptive_only",
            "notes": "Locked Step 3 leakage-aware gate: each class must have at least 5 composition_group_id groups.",
        }
    )
    if expected_gate_status == "pass":
        action = "continue_three_class"
    elif expected_gate_status == "warning":
        action = "conservative_route_a"
    else:
        action = "stop_endpoint"
    gate_rows.append(
        {
            "gate_name": "main_test_n_expected_20pct_audit_only",
            "surface_type": cls,
            "observed_value": expected_test_n_floor,
            "threshold_value": MAIN_TEST_N_NORMAL_THRESHOLD,
            "gate_result": expected_gate_status,
            "action": action,
            "notes": (
                "Audit-only expected value using floor(0.20 * class_n). "
                "The actual main split and final per-class test n must be rechecked in Step 4."
            ),
        }
    )

t15 = pd.DataFrame(gate_rows)

