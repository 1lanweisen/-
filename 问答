def baseline_values(y_train: np.ndarray, y_test: np.ndarray) -> dict[str, float]:
    train_counts = pd.Series(y_train).value_counts(normalize=True).reindex(list(INT_TO_CLASS.keys())).fillna(0.0)
    test_counts = pd.Series(y_test).value_counts(normalize=True).reindex(list(INT_TO_CLASS.keys())).fillna(0.0)
    prior_random_expected_accuracy = float((train_counts * test_counts).sum())
    uniform_random_expected_accuracy = 1.0 / len(EXPECTED_CLASSES)
    majority_label = int(pd.Series(y_train).value_counts().idxmax())
    majority_pred = np.repeat(majority_label, len(y_test))
    majority_metrics = compute_metrics(y_test, majority_pred)
    return {
        "uniform_random_expected_accuracy": uniform_random_expected_accuracy,
        "prior_random_expected_accuracy": prior_random_expected_accuracy,
        "majority_class_accuracy": majority_metrics["accuracy"],
        "majority_class_macro_f1": majority_metrics["macro_f1"],
        "random_accuracy_reference": max(uniform_random_expected_accuracy, prior_random_expected_accuracy),
        "majority_label": float(majority_label),
    }

