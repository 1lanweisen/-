def build_field_dictionary(df: pd.DataFrame) -> pd.DataFrame:
    rows = []

    standard_map = {
        "id": ("sample_id", "primary_key"),
        "name": ("sample_name", "sample_metadata"),
        "surface_type": ("surface_type_raw", "surface_label_raw"),
        "from_orton_cone": ("from_orton_cone_raw", "cone_raw"),
        "to_orton_cone": ("to_orton_cone_raw", "cone_raw"),
    }

    for raw_col, std_col in CORE_OXIDE_RAW_TO_STD.items():
        standard_map[raw_col] = (std_col, "core_oxide_percent_feature")

    for col in df.columns:
        if col in standard_map:
            std_field, role = standard_map[col]
            required = True
            transform = "copied_or_standardized_in_step1"
        else:
            std_field = ""
            role = "not_used_in_step1"
            required = False
            transform = "not_used"

        rows.append(
            {
                "raw_field": col,
                "standard_field": std_field,
                "field_role": role,
                "raw_dtype_after_locked_read": str(df[col].dtype),
                "required_for_step1": required,
                "allowed_missing_in_step1_input": False if col in REQUIRED_COLUMNS else True,
                "transformation_rule": transform,
                "notes": "",
            }
        )

    generated_fields = [
        ("source_row_number", "audit_row_id", "generated from original CSV row order"),
        ("surface_type", "three_class_endpoint", "strict map: Glossy/Matte/Satin only"),
        ("from_orton_cone_parsed", "cone_parsed", "Orton parser; 04/06/010 parsed as negative"),
        ("to_orton_cone_parsed", "cone_parsed", "Orton parser; 04/06/010 parsed as negative"),
        ("cone_min", "cone_interval", "min of parsed from/to cone"),
        ("cone_max", "cone_interval", "max of parsed from/to cone"),
        ("cone_overlap_min_6_10", "cone_high_fire_overlap", "max(cone_min, 6)"),
        ("cone_overlap_max_6_10", "cone_high_fire_overlap", "min(cone_max, 10)"),
        ("in_high_fire_window_6_10", "inclusion_flag", "True if interval intersects [6,10]"),
        ("cone_stratum", "cone_stratum", "standardized high-fire overlap stratum"),
        ("include_step1", "inclusion_flag", "True for final Step 1 retained samples"),
        ("exclusion_reason_step1", "audit_exclusion_reason", "first failed Step 1 gate"),
        ("source_file", "audit_source_file", "input filename"),
        ("source_sha256", "audit_source_hash", "input file sha256"),
        ("created_at_utc", "audit_timestamp", "script run timestamp"),
    ]

    for field, role, note in generated_fields:
        rows.append(
