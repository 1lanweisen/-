def inspect_step_code(path: Path):
    section("1. STEP 5 CODE STATIC AUDIT")
    file_basic(path)
    if not path.exists():
        print("[MISSING] step code not found")
        return

    text = path.read_text(encoding="utf-8", errors="replace")
    lines = text.splitlines()

    print(f"\nline_count: {len(lines)}")

    print("\nimportant grep hits:")
    patterns = [
        "read_parquet", "read_csv", "to_csv", "to_parquet",
        "XGB", "XGBClassifier", "PCA", "StandardScaler",
        "fit_transform", ".fit(", ".transform(", "confusion_matrix",
        "classification_report", "accuracy", "macro", "f1",
        "train", "test", "leakage", "feature_whitelist",
        "png", "savefig",
    ]
    for i, line in enumerate(lines, start=1):
        low = line.lower()
        if any(p.lower() in low for p in patterns):
            print(f"L{i:04d}: {line[:240]}")

    print("\nAST imports/functions/key calls:")
    try:
        tree = ast.parse(text)
    except Exception as e:
        print(f"[AST PARSE ERROR] {repr(e)}")
        return

    imports = []
    funcs = []
    calls = []

    class V(ast.NodeVisitor):
        def visit_Import(self, node):
            for alias in node.names:
                imports.append((node.lineno, alias.name, alias.asname))
            self.generic_visit(node)

        def visit_ImportFrom(self, node):
            mod = node.module or ""
            for alias in node.names:
                imports.append((node.lineno, f"{mod}.{alias.name}", alias.asname))
            self.generic_visit(node)

        def visit_FunctionDef(self, node):
            funcs.append((node.lineno, node.name, [a.arg for a in node.args.args]))
            self.generic_visit(node)

        def visit_Call(self, node):
            name = self.call_name(node.func)
            kw = [k.arg for k in node.keywords if k.arg is not None]
            if name:
                calls.append((node.lineno, name, kw))
            self.generic_visit(node)

        def call_name(self, f):
            if isinstance(f, ast.Name):
                return f.id
            if isinstance(f, ast.Attribute):
                base = self.call_name(f.value)
                return f"{base}.{f.attr}" if base else f.attr
            return None

    V().visit(tree)

    print("\nimports:")
    for lineno, name, asname in imports:
        print(f"L{lineno:04d}: {name}" + (f" as {asname}" if asname else ""))

    print("\nfunction_defs:")
    for lineno, name, args in funcs:
        print(f"L{lineno:04d}: def {name}({', '.join(args)})")

    key_call_regex = re.compile(
        r"(read_parquet|read_csv|to_csv|to_parquet|XGB|XGBClassifier|PCA|StandardScaler|"
        r"Pipeline|confusion_matrix|classification_report|accuracy|f1|fit|fit_transform|transform|predict|savefig)",
        re.I,
    )

    print("\nkey_calls_with_keywords:")
    n = 0
    for lineno, name, kw in calls:
        if key_call_regex.search(name):
            print(f"L{lineno:04d}: call={name} kwargs={kw}")
            n += 1
    print(f"key_call_count_printed: {n}")

