def build_split_output(df: pd.DataFrame, train_idx: np.ndarray, test_idx: np.ndarray, split_info: dict[str, Any]) -> pd.DataFrame:
    out = df[[ID_COL, TARGET_COL, GROUP_COL, CONE_COL]].copy()
    out["split"] = "train"
    out.loc[df.index[test_idx], "split"] = "test"
    out["selected_seed"] = int(split_info["seed"])
    out["seed_rank"] = int(split_info["seed_rank"])
    out["group_leakage_check"] = bool(split_info["group_leakage_pass"])
    out["class_count_gate"] = bool(split_info["class_count_gate_pass"])
    out["class_prop_gate"] = bool(split_info["class_prop_gate_pass"])
    out["max_class_prop_deviation_pp"] = float(split_info["max_class_prop_deviation_pp"])
    for cls in EXPECTED_CLASSES:
        out[f"test_n_{cls}"] = int(split_info[f"test_n_{cls}"])
        out[f"test_prop_deviation_pp_{cls}"] = float(split_info[f"test_prop_deviation_pp_{cls}"])
    return out

def build_hyperparameter_output(model_comparison: pd.DataFrame) -> pd.DataFrame:
    rows = []
    best_by_model = {
        row["model_name"]: json.loads(row["best_params_json"])
        for _, row in model_comparison.dropna(subset=["best_params_json"]).iterrows()
    }
    for model_name in MODEL_ORDER:
        for param_name, values in HYPERPARAMETER_SPACE[model_name].items():
            best_params = best_by_model.get(model_name, {})
            rows.append(
                {
                    "model_name": model_name,
                    "parameter_name": param_name,
                    "search_values": json_dumps(values),
                    "source": "locked_plan_step4_and_Cho_2026_method_alignment",
                    "final_value": json_dumps(best_params.get(param_name, None)),
                    "selection_basis": "highest_training_cv_macro_f1_then_cv_accuracy_then_cv_satin_f1",
                }
            )
    return pd.DataFrame(rows)

def build_performance_summary(model_comparison: pd.DataFrame) -> pd.DataFrame:
    rows = []
    ranked = model_comparison.sort_values(
        by=["cv_macro_f1_mean", "cv_accuracy_mean", "test_macro_f1"],
        ascending=[False, False, False],
        kind="mergesort",
    ).reset_index(drop=True)
    for rank, (_, row) in enumerate(ranked.iterrows(), start=1):
        rows.append(
            {
                "rank": rank,
                "model_name": row["model_name"],
                "cv_macro_f1_mean": row["cv_macro_f1_mean"],
                "cv_macro_f1_sd": row["cv_macro_f1_sd"],
                "test_accuracy": row["test_accuracy"],
                "test_macro_f1": row["test_macro_f1"],
                "test_balanced_accuracy": row["test_balanced_accuracy"],
                "test_satin_recall": row["test_satin_recall"],
                "test_satin_f1": row["test_satin_f1"],
                "selected_as_best": row["selected_as_best"],
                "remark": row["selection_rule"],
            }
        )
    return pd.DataFrame(rows)

def build_f04_data(model_comparison: pd.DataFrame) -> pd.DataFrame:
    rows = []
    metric_cols = [
        "cv_macro_f1_mean",
        "cv_accuracy_mean",
        "test_accuracy",
        "test_macro_f1",
        "test_balanced_accuracy",
        "test_satin_f1",
        "test_satin_recall",
    ]
    for _, row in model_comparison.iterrows():
        for metric in metric_cols:
            rows.append(
                {
                    "panel": "model_performance",
                    "model_name": row["model_name"],
                    "metric": metric,
                    "value": safe_float(row.get(metric, np.nan)),
                    "selected_as_best": bool(row.get("selected_as_best", False)),
                    "notes": "Plot-ready Step 4 data only; PNG intentionally not generated in Step 4.",
                }
            )
    return pd.DataFrame(rows)

