def parse_orton_cone(value: Any) -> tuple[float | None, str]:
    """
    解析 Orton cone。

    规则：
    "6"         ->  6
    "10"        ->  10
    "04"        -> -4
    "06"        -> -6
    "010"       -> -10
    "5 &#189;"  ->  5.5
    "05 &#189;" -> -5.5
    """
    if is_missing_like(value):
        return None, "missing"

    raw = html.unescape(str(value)).strip()
    raw = raw.replace("\u00a0", " ")

    has_half = False
    if "½" in raw or "1/2" in raw:
        has_half = True
        raw = raw.replace("½", "")
        raw = raw.replace("1/2", "")

    raw_clean = raw.strip()
    m = re.search(r"[-+]?\d+(?:\.\d+)?", raw_clean)
    if not m:
        return None, "unparseable"

    token = m.group(0)
    sign = -1 if token.startswith("-") else 1
    token_no_sign = token.lstrip("+-")

    # 前导 0 的 Orton cone 视为低温 zero-cone。
    if (
        sign > 0
        and len(token_no_sign) > 1
        and token_no_sign.startswith("0")
        and token_no_sign.replace(".", "", 1).isdigit()
    ):
        base_digits = token_no_sign.lstrip("0")
        base = 0.0 if base_digits == "" else float(base_digits)
        parsed = -base
        if has_half:
            parsed -= 0.5
        return parsed, "parsed_zero_cone_as_negative"

    try:
        parsed = float(token)
    except ValueError:
        return None, "unparseable"

    if has_half:
        parsed += 0.5 if parsed >= 0 else -0.5

    return parsed, "parsed_positive_or_numeric"

def format_cone_value(x: float) -> str:
    if float(x).is_integer():
        return str(int(x))
    return str(x).replace(".", "p")

def build_cone_fields(df: pd.DataFrame) -> pd.DataFrame:
    from_values = []
    to_values = []
    from_statuses = []
    to_statuses = []
    cone_mins = []
    cone_maxs = []
    cone_statuses = []
    overlap_mins = []
    overlap_maxs = []
    in_high_window = []
    strata = []

    for _, row in df.iterrows():
        f_val, f_status = parse_orton_cone(row.get("from_orton_cone", ""))
        t_val, t_status = parse_orton_cone(row.get("to_orton_cone", ""))

        from_values.append(f_val)
        to_values.append(t_val)
        from_statuses.append(f_status)
        to_statuses.append(t_status)

        vals = [v for v in [f_val, t_val] if v is not None]

        if not vals:
            cone_mins.append(pd.NA)
            cone_maxs.append(pd.NA)
            cone_statuses.append("cone_missing_or_unparseable")
            overlap_mins.append(pd.NA)
            overlap_maxs.append(pd.NA)
            in_high_window.append(False)
            strata.append(pd.NA)
            continue

        cmin = min(vals)
        cmax = max(vals)

        ov_min = max(cmin, HIGH_FIRE_MIN)
        ov_max = min(cmax, HIGH_FIRE_MAX)
        overlaps = ov_min <= ov_max

        cone_mins.append(cmin)
        cone_maxs.append(cmax)

        if f_val is not None and t_val is not None:
            cone_statuses.append("parsed_both")
        elif f_val is not None:
            cone_statuses.append("parsed_from_only")
        else:
            cone_statuses.append("parsed_to_only")

        if overlaps:
            overlap_mins.append(ov_min)
            overlap_maxs.append(ov_max)
            in_high_window.append(True)

            if ov_min == ov_max:
                strata.append(f"cone_{format_cone_value(ov_min)}")
            else:
                strata.append(f"cone_{format_cone_value(ov_min)}_to_{format_cone_value(ov_max)}_overlap")
        else:
            overlap_mins.append(pd.NA)
            overlap_maxs.append(pd.NA)
            in_high_window.append(False)
            strata.append(pd.NA)

    out = df.copy()
    out["from_orton_cone_parsed"] = from_values
    out["to_orton_cone_parsed"] = to_values
    out["from_orton_cone_parse_status"] = from_statuses
    out["to_orton_cone_parse_status"] = to_statuses
    out["cone_min"] = cone_mins
    out["cone_max"] = cone_maxs
    out["cone_parse_status"] = cone_statuses
    out["cone_overlap_min_6_10"] = overlap_mins
    out["cone_overlap_max_6_10"] = overlap_maxs
    out["in_high_fire_window_6_10"] = in_high_window
    out["cone_stratum"] = strata
