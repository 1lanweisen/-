def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def ensure_dirs() -> None:
    for d in [CODE_DIR, RAW_DIR, OUT_DIR]:
        if not d.exists():
            raise FileNotFoundError(f"固定目录不存在：{d}")

    # 只创建方案指定输出子目录
    for d in [DATA_INTERIM_DIR, TABLES_DIR, FIGURES_DIR]:
        d.mkdir(parents=True, exist_ok=True)

def is_missing_like(x: Any) -> bool:
    if x is None:
        return True
    s = str(x).strip()
    return s == "" or s.lower() in {"null", "none", "nan", "na", "n/a"}

def read_csv_locked(path: Path) -> pd.DataFrame:
    if not path.exists():
        raise FileNotFoundError(f"未找到 Step 1 输入文件：{path}")
    if path.stat().st_size == 0:
        raise ValueError(f"Step 1 输入文件为空：{path}")

    # 全部按字符串读取，防止 from_orton_cone 中的 04、06、010 被错误转成 4、6、10。
    return pd.read_csv(
        path,
        dtype=str,
        encoding="utf-8-sig",
        keep_default_na=False,
        na_values=[],
        low_memory=False,
    )

def validate_required_columns(df: pd.DataFrame) -> None:
    missing = [c for c in REQUIRED_COLUMNS if c not in df.columns]
    if missing:
        raise ValueError(
            "Step 1 必需字段缺失，禁止继续执行。缺失字段："
            + ", ".join(missing)
        )

def parse_orton_cone(value: Any) -> tuple[float | None, str]:
    """
    将 Glazy 的 Orton cone 字段解析为数值。

    关键规则：
    - "6"  -> 6
    - "10" -> 10
    - "04" -> -4
    - "06" -> -6
    - "010" -> -10
    - "5 &#189;" -> 5.5
    - "05 &#189;" -> -5.5

    返回：(parsed_value, parse_status)
    """
    if is_missing_like(value):
        return None, "missing"

    raw = html.unescape(str(value)).strip()
    raw = raw.replace("\u00a0", " ")

    has_half = False
    if "½" in raw or "1/2" in raw:
        has_half = True
        raw = raw.replace("½", "")
        raw = raw.replace("1/2", "")

    raw_clean = raw.strip()

    # 只保留数字、点号、正负号；兼容 "Cone 6" 这类异常写法
    m = re.search(r"[-+]?\d+(?:\.\d+)?", raw_clean)
    if not m:
        return None, "unparseable"

    token = m.group(0)
    sign = -1 if token.startswith("-") else 1
    token_no_sign = token.lstrip("+-")

    # Orton zero-cone：前导 0 且长度>1，内部表示为负数，防止误判为高温正 cone
    if (
        sign > 0
        and len(token_no_sign) > 1
        and token_no_sign.startswith("0")
        and token_no_sign.replace(".", "", 1).isdigit()
    ):
        base_digits = token_no_sign.lstrip("0")
        if base_digits == "":
            base = 0.0
        else:
            base = float(base_digits)
        parsed = -base
        if has_half:
            parsed -= 0.5
        return parsed, "parsed_zero_cone_as_negative"

    try:
        parsed = float(token)
    except ValueError:
        return None, "unparseable"

    if has_half:
        parsed += 0.5 if parsed >= 0 else -0.5

    return parsed, "parsed_positive_or_numeric"

def build_cone_fields(df: pd.DataFrame) -> pd.DataFrame:
    from_values = []
    to_values = []
    from_statuses = []
    to_statuses = []
    cone_mins = []
    cone_maxs = []
    cone_statuses = []
    overlap_mins = []
    overlap_maxs = []
    in_high_window = []
    strata = []

    for _, row in df.iterrows():
        f_raw = row.get("from_orton_cone", "")
        t_raw = row.get("to_orton_cone", "")

        f_val, f_status = parse_orton_cone(f_raw)
        t_val, t_status = parse_orton_cone(t_raw)

        from_values.append(f_val)
        to_values.append(t_val)
        from_statuses.append(f_status)
        to_statuses.append(t_status)

        vals = [v for v in [f_val, t_val] if v is not None]

        if len(vals) == 0:
            cone_mins.append(pd.NA)
            cone_maxs.append(pd.NA)
            cone_statuses.append("cone_missing_or_unparseable")
            overlap_mins.append(pd.NA)
            overlap_maxs.append(pd.NA)
            in_high_window.append(False)
            strata.append(pd.NA)
            continue

        cmin = min(vals)
        cmax = max(vals)

        ov_min = max(cmin, HIGH_FIRE_MIN)
        ov_max = min(cmax, HIGH_FIRE_MAX)
        overlaps = ov_min <= ov_max

        cone_mins.append(cmin)
        cone_maxs.append(cmax)

        if f_val is not None and t_val is not None:
            cone_statuses.append("parsed_both")
        elif f_val is not None:
            cone_statuses.append("parsed_from_only")
        else:
            cone_statuses.append("parsed_to_only")

        if overlaps:
            overlap_mins.append(ov_min)
            overlap_maxs.append(ov_max)
            in_high_window.append(True)

            if ov_min == ov_max:
                strata.append(f"cone_{format_cone_value(ov_min)}")
            else:
                strata.append(
                    f"cone_{format_cone_value(ov_min)}_to_{format_cone_value(ov_max)}_overlap"
                )
        else:
            overlap_mins.append(pd.NA)
            overlap_maxs.append(pd.NA)
            in_high_window.append(False)
            strata.append(pd.NA)

    out = df.copy()
    out["from_orton_cone_parsed"] = from_values
    out["to_orton_cone_parsed"] = to_values
    out["from_orton_cone_parse_status"] = from_statuses
    out["to_orton_cone_parse_status"] = to_statuses
    out["cone_min"] = cone_mins
    out["cone_max"] = cone_maxs
    out["cone_parse_status"] = cone_statuses
    out["cone_overlap_min_6_10"] = overlap_mins
    out["cone_overlap_max_6_10"] = overlap_maxs
    out["in_high_fire_window_6_10"] = in_high_window
    out["cone_stratum"] = strata

    return out

def format_cone_value(x: float) -> str:
    if float(x).is_integer():
        return str(int(x))
    return str(x).replace(".", "p")

def write_csv(df: pd.DataFrame, path: Path) -> None:
    df.to_csv(path, index=False, encoding="utf-8", quoting=csv.QUOTE_MINIMAL)

def build_field_dictionary(df: pd.DataFrame) -> pd.DataFrame:
    rows = []

    standard_map = {
        "id": ("sample_id", "primary_key"),
        "name": ("sample_name", "sample_metadata"),
        "surface_type": ("surface_type_raw", "surface_label_raw"),
        "from_orton_cone": ("from_orton_cone_raw", "cone_raw"),
        "to_orton_cone": ("to_orton_cone_raw", "cone_raw"),
    }

    for raw_col, std_col in CORE_OXIDE_RAW_TO_STD.items():
        standard_map[raw_col] = (std_col, "core_oxide_percent_feature")

    for col in df.columns:
        if col in standard_map:
            std_field, role = standard_map[col]
            required = True
            transform = "copied_or_standardized_in_step1"
        else:
            std_field = ""
            role = "not_used_in_step1"
            required = False
            transform = "not_used"

        rows.append(
            {
                "raw_field": col,
                "standard_field": std_field,
                "field_role": role,
                "raw_dtype_after_locked_read": str(df[col].dtype),
                "required_for_step1": required,
                "allowed_missing_in_step1_input": False if col in REQUIRED_COLUMNS else True,
                "transformation_rule": transform,
                "notes": "",
            }
        )

    # 追加 Step 1 生成字段，便于审计
    generated_fields = [
        ("source_row_number", "audit_row_id", "generated from original CSV row order"),
        ("surface_type", "three_class_endpoint", "strict map: Glossy/Matte/Satin only"),
        ("from_orton_cone_parsed", "cone_parsed", "Orton parser; 04/06/010 parsed as negative"),
        ("to_orton_cone_parsed", "cone_parsed", "Orton parser; 04/06/010 parsed as negative"),
        ("cone_min", "cone_interval", "min of parsed from/to cone"),
        ("cone_max", "cone_interval", "max of parsed from/to cone"),
        ("cone_overlap_min_6_10", "cone_high_fire_overlap", "max(cone_min, 6)"),
        ("cone_overlap_max_6_10", "cone_high_fire_overlap", "min(cone_max, 10)"),
        ("in_high_fire_window_6_10", "inclusion_flag", "True if interval intersects [6,10]"),
        ("cone_stratum", "cone_stratum", "standardized high-fire overlap stratum"),
        ("include_step1", "inclusion_flag", "True for final Step 1 retained samples"),
        ("exclusion_reason_step1", "audit_exclusion_reason", "first failed Step 1 gate"),
        ("source_file", "audit_source_file", "input filename"),
        ("source_sha256", "audit_source_hash", "input file sha256"),
        ("created_at_utc", "audit_timestamp", "script run timestamp"),
    ]

    for field, role, note in generated_fields:
        rows.append(
            {
                "raw_field": "",
                "standard_field": field,
                "field_role": role,
                "raw_dtype_after_locked_read": "",
                "required_for_step1": True,
                "allowed_missing_in_step1_input": "",
                "transformation_rule": "generated_by_step1_script",
                "notes": note,
            }
        )

    return pd.DataFrame(rows)

def build_surface_mapping_table(df: pd.DataFrame) -> pd.DataFrame:
    s = df["surface_type"].astype(str).str.strip()
    vc = s.value_counts(dropna=False).rename_axis("surface_type_raw").reset_index(name="n_records")

    rows = []
    for _, r in vc.iterrows():
        raw = r["surface_type_raw"]
        mapped = STRICT_SURFACE_MAP.get(raw, "")
        include = raw in STRICT_SURFACE_MAP
        if include:
            reason = ""
            status = "mapped_strict_three_class"
        else:
            reason = "surface_not_in_strict_Glossy_Matte_Satin"
            status = "excluded_to_prevent_endpoint_contamination"
        rows.append(
            {
                "surface_type_raw": raw,
                "surface_type_mapped": mapped,
                "mapping_status": status,
                "n_records": int(r["n_records"]),
                "include_in_step1": include,
                "exclusion_reason": reason,
                "locking_comment": (
                    "Only exact Glossy/Matte/Satin are retained. Hybrid labels are excluded "
                    "because the endpoint is to test whether Satin is distinct or transitional."
                ),
            }
        )

    return pd.DataFrame(rows)

def build_cone_strata_table(df: pd.DataFrame) -> pd.DataFrame:
    group_cols = [
        "from_orton_cone",
        "to_orton_cone",
        "from_orton_cone_parsed",
        "to_orton_cone_parsed",
        "cone_min",
        "cone_max",
        "cone_overlap_min_6_10",
        "cone_overlap_max_6_10",
        "cone_stratum",
        "cone_parse_status",
        "in_high_fire_window_6_10",
    ]

    tmp = df.copy()
    tmp["after_surface_strict_gate"] = tmp["surface_type"].isin(STRICT_SURFACE_MAP)

    table = (
        tmp.groupby(group_cols, dropna=False)
        .agg(
            n_records_total=("id", "size"),
            n_records_after_surface_strict_gate=("after_surface_strict_gate", "sum"),
        )
        .reset_index()
    )

    table["exclusion_reason_if_not_high_fire"] = table["in_high_fire_window_6_10"].map(
        lambda x: "" if bool(x) else "cone_not_overlapping_6_10_or_unparseable"
    )

    table["locking_comment"] = (
        "Cone range is retained when parsed from/to interval intersects [6,10]. "
        "Leading-zero Orton cones such as 04/06/010 are parsed as negative low-fire cones."
    )

    return table.sort_values(
        by=["in_high_fire_window_6_10", "n_records_total"],
        ascending=[False, False],
    )

def build_flow_tables(df: pd.DataFrame) -> tuple[pd.DataFrame, pd.DataFrame]:
    n0 = len(df)

    surface_ok = df["surface_type"].isin(STRICT_SURFACE_MAP)
    n1 = int(surface_ok.sum())
    e1 = n0 - n1

    cone_parsed_ok = surface_ok & df["cone_min"].notna() & df["cone_max"].notna()
    n2 = int(cone_parsed_ok.sum())
    e2 = n1 - n2

    high_fire_ok = cone_parsed_ok & df["in_high_fire_window_6_10"].astype(bool)
    n3 = int(high_fire_ok.sum())
    e3 = n2 - n3

    flow_rows = [
        {
            "stage_order": 0,
            "stage_name": "raw_glazy_20211130_glazes_csv",
            "n_input": n0,
            "n_excluded": 0,
            "n_retained": n0,
            "exclusion_reason": "",
            "retained_ratio_of_initial": 1.0,
        },
        {
            "stage_order": 1,
            "stage_name": "strict_surface_three_class_mapping",
            "n_input": n0,
            "n_excluded": e1,
            "n_retained": n1,
            "exclusion_reason": "surface_not_in_strict_Glossy_Matte_Satin",
            "retained_ratio_of_initial": n1 / n0 if n0 else 0,
        },
        {
            "stage_order": 2,
            "stage_name": "cone_from_to_parseable",
            "n_input": n1,
            "n_excluded": e2,
            "n_retained": n2,
            "exclusion_reason": "cone_missing_or_unparseable_after_surface_gate",
            "retained_ratio_of_initial": n2 / n0 if n0 else 0,
        },
        {
            "stage_order": 3,
            "stage_name": "cone_interval_overlaps_6_to_10",
            "n_input": n2,
            "n_excluded": e3,
            "n_retained": n3,
            "exclusion_reason": "cone_interval_does_not_overlap_6_to_10",
            "retained_ratio_of_initial": n3 / n0 if n0 else 0,
        },
    ]

    flow = pd.DataFrame(flow_rows)

    fig_rows = [
        {
            "node_order": 0,
            "node_label": "Raw Glazy glazes CSV",
            "n_samples": n0,
            "percent_of_raw": 100.0,
            "parent_node": "",
            "exclusion_reason": "",
        },
        {
            "node_order": 1,
            "node_label": "Retained: strict Surface = Glossy/Matte/Satin",
            "n_samples": n1,
            "percent_of_raw": 100.0 * n1 / n0 if n0 else 0,
            "parent_node": "Raw Glazy glazes CSV",
            "exclusion_reason": "",
        },
        {
            "node_order": 2,
            "node_label": "Excluded: Surface outside strict three classes",
            "n_samples": e1,
            "percent_of_raw": 100.0 * e1 / n0 if n0 else 0,
            "parent_node": "Raw Glazy glazes CSV",
            "exclusion_reason": "surface_not_in_strict_Glossy_Matte_Satin",
        },
        {
            "node_order": 3,
            "node_label": "Retained: Cone parseable",
            "n_samples": n2,
            "percent_of_raw": 100.0 * n2 / n0 if n0 else 0,
            "parent_node": "Retained: strict Surface = Glossy/Matte/Satin",
            "exclusion_reason": "",
        },
        {
            "node_order": 4,
            "node_label": "Excluded: Cone missing or unparseable",
            "n_samples": e2,
            "percent_of_raw": 100.0 * e2 / n0 if n0 else 0,
            "parent_node": "Retained: strict Surface = Glossy/Matte/Satin",
            "exclusion_reason": "cone_missing_or_unparseable_after_surface_gate",
        },
        {
            "node_order": 5,
            "node_label": "Retained: Cone interval overlaps 6-10",
            "n_samples": n3,
            "percent_of_raw": 100.0 * n3 / n0 if n0 else 0,
            "parent_node": "Retained: Cone parseable",
            "exclusion_reason": "",
        },
        {
            "node_order": 6,
            "node_label": "Excluded: Cone interval outside 6-10",
            "n_samples": e3,
            "percent_of_raw": 100.0 * e3 / n0 if n0 else 0,
            "parent_node": "Retained: Cone parseable",
            "exclusion_reason": "cone_interval_does_not_overlap_6_to_10",
        },
    ]

    fig_data = pd.DataFrame(fig_rows)

    return flow, fig_data

def assign_exclusion_reason(df: pd.DataFrame) -> pd.Series:
    reasons = []
    for _, row in df.iterrows():
        raw_surface = str(row.get("surface_type", "")).strip()
        if raw_surface not in STRICT_SURFACE_MAP:
            reasons.append("surface_not_in_strict_Glossy_Matte_Satin")
            continue

        if pd.isna(row.get("cone_min")) or pd.isna(row.get("cone_max")):
            reasons.append("cone_missing_or_unparseable_after_surface_gate")
            continue

        if not bool(row.get("in_high_fire_window_6_10")):
            reasons.append("cone_interval_does_not_overlap_6_to_10")
            continue

        reasons.append("")

    return pd.Series(reasons, index=df.index)

def main() -> None:
    ensure_dirs()

    print("=" * 100)
    print("STEP 1 START")
    print("=" * 100)
    print(f"time_utc: {datetime.now(timezone.utc).isoformat()}")
    print(f"python: {sys.version}")
    print(f"raw_file: {RAW_FILE}")
    print(f"output_parquet: {OUTPUT_PARQUET}")
    print()

    raw_sha256 = sha256_file(RAW_FILE)
    df = read_csv_locked(RAW_FILE)
    validate_required_columns(df)

    if df.columns.duplicated().any():
        dups = df.columns[df.columns.duplicated()].tolist()
        raise ValueError(f"CSV 存在重复列名，禁止继续：{dups}")

    print("INPUT CHECK")
    print(f"raw_rows: {len(df)}")
    print(f"raw_columns: {len(df.columns)}")
    print(f"raw_sha256: {raw_sha256}")
    print()

    # 保留原始行号，便于追溯到 CSV
    df = df.copy()
    df["source_row_number"] = range(2, len(df) + 2)  # CSV 第 1 行是表头，因此数据从第 2 行开始

    # Surface 严格三分类
    df["surface_type_raw"] = df["surface_type"].astype(str).str.strip()
    df["surface_type_mapped"] = df["surface_type_raw"].map(STRICT_SURFACE_MAP)

    # Cone 解析与高温窗口交集判定
    df = build_cone_fields(df)

    # Step 1 纳入/排除
    df["exclusion_reason_step1"] = assign_exclusion_reason(df)
    df["include_step1"] = df["exclusion_reason_step1"].eq("")

    # 生成标准化主表：只输出 Step 1 纳入样本
    retained = df.loc[df["include_step1"]].copy()

    out = pd.DataFrame()
    out["sample_id"] = retained["id"].astype(str)
    out["sample_name"] = retained["name"].astype(str)
    out["source_row_number"] = retained["source_row_number"]
    out["surface_type_raw"] = retained["surface_type_raw"]
    out["surface_type"] = retained["surface_type_mapped"]

    out["from_orton_cone_raw"] = retained["from_orton_cone"].astype(str)
    out["to_orton_cone_raw"] = retained["to_orton_cone"].astype(str)
    out["from_orton_cone_parsed"] = pd.to_numeric(retained["from_orton_cone_parsed"], errors="coerce")
    out["to_orton_cone_parsed"] = pd.to_numeric(retained["to_orton_cone_parsed"], errors="coerce")
    out["cone_min"] = pd.to_numeric(retained["cone_min"], errors="coerce")
    out["cone_max"] = pd.to_numeric(retained["cone_max"], errors="coerce")
    out["cone_overlap_min_6_10"] = pd.to_numeric(retained["cone_overlap_min_6_10"], errors="coerce")
    out["cone_overlap_max_6_10"] = pd.to_numeric(retained["cone_overlap_max_6_10"], errors="coerce")
    out["cone_stratum"] = retained["cone_stratum"].astype(str)

    for raw_col, std_col in CORE_OXIDE_RAW_TO_STD.items():
        out[std_col] = pd.to_numeric(retained[raw_col], errors="coerce")

    out["include_step1"] = True
    out["exclusion_reason_step1"] = ""
    out["source_file"] = RAW_FILE.name
    out["source_sha256"] = raw_sha256
    out["created_at_utc"] = datetime.now(timezone.utc).isoformat()

    # 表格输出
    field_dictionary = build_field_dictionary(df)
    surface_mapping = build_surface_mapping_table(df)
    cone_strata = build_cone_strata_table(df)
    inclusion_flow, flow_data = build_flow_tables(df)

    # 写出
    out.to_parquet(OUTPUT_PARQUET, index=False)
    write_csv(field_dictionary, T01_FIELD_DICTIONARY)
    write_csv(surface_mapping, T02_SURFACE_MAPPING)
    write_csv(cone_strata, T03_CONE_STRATA)
    write_csv(inclusion_flow, T04_INCLUSION_FLOW)
    write_csv(flow_data, F01_FLOW_DATA)

    # 运行摘要
    print("=" * 100)
    print("LOCKED RULES")
    print("=" * 100)
    print("surface_rule: exact-only Glossy / Matte / Satin; all hybrid labels excluded")
    print("surface_reason: avoid contaminating the Satin endpoint with transitional labels")
    print("cone_rule: parsed interval intersects [6, 10]")
    print("cone_reason: from/to_orton_cone represents applicable firing range")
    print("orton_zero_cone_rule: leading-zero cones such as 04/06/010 are parsed as negative low-fire cones")
    print("step1_boundary: no oxide-sum QC, no 100 wt% normalization, no duplicate removal, no composition_group_id")
    print("plotting_boundary: no PNG generated in Step 1; only F01 plotting data CSV is generated")
    print()

    print("=" * 100)
    print("COUNTS")
    print("=" * 100)
    print("raw_n:", len(df))
    print("retained_step1_n:", len(out))
    print("excluded_step1_n:", len(df) - len(out))
    print()
    print("surface_counts_raw:")
    print(df["surface_type_raw"].value_counts(dropna=False).to_string())
    print()
