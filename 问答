def utc_now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()

def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def write_csv_utf8(df: pd.DataFrame, path: Path) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    df.to_csv(path, index=False, encoding="utf-8-sig", lineterminator="\n")

def read_csv_utf8(path: Path) -> pd.DataFrame:
    return pd.read_csv(path, encoding="utf-8-sig")

def fail_if_missing_columns(df: pd.DataFrame, required_cols: Iterable[str], object_name: str) -> None:
    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise RuntimeError(f"{object_name} missing required columns: {', '.join(missing)}")

def json_dumps(obj: Any) -> str:
    return json.dumps(obj, ensure_ascii=False, sort_keys=True, default=str)

def normalize_sample_id_key(value: Any) -> str:
    """
    Make a temporary merge key only.

    Reason:
    pandas may read sample_id from CSV as int64 while parquet keeps it as object/string.
    This function avoids merge failure without changing any original file or analytical value.
    """
    if value is None or pd.isna(value):
        return ""

    s = str(value).strip()

    # Convert "123.0" to "123" when CSV/parquet type inference created float-like IDs.
    if re.fullmatch(r"\d+\.0+", s):
        s = s.split(".", 1)[0]

    return s

def parse_params_from_model_comparison(model_comparison: pd.DataFrame, model_name: str) -> dict[str, Any]:
    rows = model_comparison.loc[model_comparison["model_name"].astype(str).eq(model_name)].copy()
    if len(rows) != 1:
        raise RuntimeError(f"Expected exactly one row for model_name={model_name}, observed {len(rows)}.")

    raw = rows.iloc[0].get("best_params_json", "")
    if pd.isna(raw) or str(raw).strip() == "":
        raise RuntimeError(f"Missing best_params_json for model_name={model_name}.")

    out = json.loads(str(raw))
    if not isinstance(out, dict):
        raise RuntimeError(f"best_params_json for {model_name} did not decode to a dict.")

    return out

def compute_metrics(y_true: np.ndarray, y_pred: np.ndarray) -> dict[str, float]:
    acc = accuracy_score(y_true, y_pred)
    macro_f1 = f1_score(
        y_true,
        y_pred,
        labels=list(INT_TO_CLASS.keys()),
        average="macro",
        zero_division=0,
    )
    bal_acc = balanced_accuracy_score(y_true, y_pred)

    precision, recall, f1, support = precision_recall_fscore_support(
        y_true,
        y_pred,
        labels=list(INT_TO_CLASS.keys()),
        zero_division=0,
    )

    return {
        "accuracy": float(acc),
        "macro_f1": float(macro_f1),
        "balanced_accuracy": float(bal_acc),
        "satin_precision": float(precision[SATIN_LABEL]),
        "satin_recall": float(recall[SATIN_LABEL]),
        "satin_f1": float(f1[SATIN_LABEL]),
        "satin_support": int(support[SATIN_LABEL]),
    }

def make_base_pipeline(model_name: str, random_state: int) -> Pipeline:
    if model_name == "PCA_LDA":
        return Pipeline(
            steps=[
                ("scaler", StandardScaler()),
                ("pca", PCA(random_state=random_state)),
                ("clf", LinearDiscriminantAnalysis()),
            ]
        )

    if model_name == "XGB":
