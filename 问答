def build_surface_mapping_table(df: pd.DataFrame) -> pd.DataFrame:
    s = df["surface_type_raw"].astype(str).str.strip()
    vc = s.value_counts(dropna=False).rename_axis("surface_type_raw").reset_index(name="n_records")

    rows = []
    for _, r in vc.iterrows():
        raw = r["surface_type_raw"]
        mapped = STRICT_SURFACE_MAP.get(raw, "")
        include = raw in STRICT_SURFACE_MAP

        if include:
            status = "mapped_strict_three_class"
            reason = ""
        else:
            status = "excluded_to_prevent_endpoint_contamination"
            reason = "surface_not_in_strict_Glossy_Matte_Satin"

        rows.append(
            {
                "surface_type_raw": raw,
                "surface_type_mapped": mapped,
                "mapping_status": status,
                "n_records": int(r["n_records"]),
                "include_in_step1": include,
                "exclusion_reason": reason,
                "locking_comment": (
                    "Only exact Glossy/Matte/Satin are retained. Hybrid labels are excluded "
                    "because the endpoint is to test whether Satin is distinct or transitional."
                ),
            }
        )

    return pd.DataFrame(rows)

def build_cone_strata_table(df: pd.DataFrame) -> pd.DataFrame:
    group_cols = [
        "from_orton_cone",
        "to_orton_cone",
        "from_orton_cone_parsed",
        "to_orton_cone_parsed",
        "cone_min",
        "cone_max",
        "cone_overlap_min_6_10",
        "cone_overlap_max_6_10",
        "cone_stratum",
        "cone_parse_status",
        "in_high_fire_window_6_10",
    ]

    tmp = df.copy()
    tmp["after_surface_strict_gate"] = tmp["surface_type_raw"].isin(STRICT_SURFACE_MAP)

    table = (
        tmp.groupby(group_cols, dropna=False)
        .agg(
            n_records_total=("id", "size"),
            n_records_after_surface_strict_gate=("after_surface_strict_gate", "sum"),
        )
        .reset_index()
    )

    table["exclusion_reason_if_not_high_fire"] = table["in_high_fire_window_6_10"].map(
        lambda x: "" if bool(x) else "cone_not_overlapping_6_10_or_unparseable"
    )
    table["locking_comment"] = (
        "Cone range is retained when parsed from/to interval intersects [6,10]. "
        "Leading-zero Orton cones such as 04/06/010 are parsed as negative low-fire cones."
    )

    return table.sort_values(
        by=["in_high_fire_window_6_10", "n_records_total"],
        ascending=[False, False],
    )

def assign_exclusion_reason(df: pd.DataFrame) -> pd.Series:
    reasons = []

    for _, row in df.iterrows():
        raw_surface = str(row.get("surface_type_raw", "")).strip()

        if raw_surface not in STRICT_SURFACE_MAP:
            reasons.append("surface_not_in_strict_Glossy_Matte_Satin")
            continue

        if pd.isna(row.get("cone_min")) or pd.isna(row.get("cone_max")):
            reasons.append("cone_missing_or_unparseable_after_surface_gate")
            continue

        if not bool(row.get("in_high_fire_window_6_10")):
            reasons.append("cone_interval_does_not_overlap_6_to_10")
            continue

        reasons.append("")

    return pd.Series(reasons, index=df.index)

