def validate_no_leakage_features(df: pd.DataFrame) -> None:
    # Modification Reason: 泄漏防护; Step 3 output contains target-derived audit columns.
    # 改动前风险: using all numeric columns would include class_n_total, class_percent_samples,
    # route_a_statement_level_step3_audit, expected_main_test_n_20pct_floor, etc.
    # 改动后差异: X is constructed only from FEATURE_COLS, and any audit-derived column in
