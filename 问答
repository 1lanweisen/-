def make_base_pipeline(model_name: str, random_state: int) -> Pipeline:
    if model_name == "PCA_LDA":
        return Pipeline([("scaler", StandardScaler()), ("pca", PCA(random_state=random_state)), ("clf", LinearDiscriminantAnalysis())])
    if model_name == "DT":
        return Pipeline([("scaler", StandardScaler()), ("clf", DecisionTreeClassifier(random_state=random_state))])
    if model_name == "RF":
        return Pipeline([("scaler", StandardScaler()), ("clf", RandomForestClassifier(random_state=random_state, n_jobs=N_JOBS_TREE))])
    if model_name == "XGB":
        if XGBClassifier is None:
            raise RuntimeError(f"xgboost is required for selected XGB. Original import error: {repr(XGB_IMPORT_ERROR)}")
        return Pipeline([
            ("scaler", StandardScaler()),
            ("clf", XGBClassifier(
                objective="multi:softprob", num_class=len(EXPECTED_CLASSES), eval_metric="mlogloss",
                random_state=random_state, seed=random_state, n_jobs=XGB_N_JOBS, tree_method="hist", verbosity=0,
            )),
        ])
    if model_name == "KNN":
        return Pipeline([("scaler", StandardScaler()), ("clf", KNeighborsClassifier())])
    if model_name == "SVM":
        return Pipeline([("scaler", StandardScaler()), ("clf", SVC())])
    raise ValueError(f"Unknown model_name: {model_name}")

def load_best_model_record(model_comparison: pd.DataFrame, t10: pd.DataFrame) -> dict[str, Any]:
    fail_if_missing_columns(model_comparison, ["model_name", "best_params_json", "selected_as_best", "selection_rule"], "04_model_comparison.csv")
    selected = model_comparison.loc[sanitize_bool_series(model_comparison["selected_as_best"]).fillna(False)].copy()
    if len(selected) != 1:
        raise RuntimeError(f"Expected exactly one selected best model in 04_model_comparison.csv, observed {len(selected)}.")
    row = selected.iloc[0]

    fail_if_missing_columns(t10, ["model_name", "rank", "selected_as_best"], "T10_model_performance_summary.csv")
    t10_selected = t10.loc[sanitize_bool_series(t10["selected_as_best"]).fillna(False)].copy()
    if len(t10_selected) != 1:
        raise RuntimeError(f"Expected exactly one selected best model in T10, observed {len(t10_selected)}.")
    if str(t10_selected.iloc[0]["model_name"]) != str(row["model_name"]):
        raise RuntimeError("Best-model mismatch between 04_model_comparison.csv and T10_model_performance_summary.csv.")

    return {
        "model_name": str(row["model_name"]),
        "best_params": parse_json_dict(row["best_params_json"]),
        "selection_rule": str(row["selection_rule"]),
        "step4_test_satin_recall": safe_float(row.get("test_satin_recall", np.nan)),
        "step4_test_satin_f1": safe_float(row.get("test_satin_f1", np.nan)),
        "step4_test_accuracy": safe_float(row.get("test_accuracy", np.nan)),
        "step4_test_macro_f1": safe_float(row.get("test_macro_f1", np.nan)),
    }

