def utc_now_iso() -> str:
    return datetime.now(timezone.utc).isoformat()

def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def require_module(name: str, hint: str) -> None:
    if importlib.util.find_spec(name) is None:
        raise RuntimeError(f"Missing module {name}. Hint: {hint}")

def write_csv_utf8(df: pd.DataFrame, path: Path) -> None:
    df.to_csv(path, index=False, encoding="utf-8-sig", lineterminator="\n")

def fail_if_missing(df: pd.DataFrame, cols: list[str], name: str) -> None:
    missing = [c for c in cols if c not in df.columns]
    if missing:
        raise RuntimeError(f"{name} missing columns: {', '.join(missing)}")

def parse_json_dict(x: Any) -> dict[str, Any]:
    if x is None or pd.isna(x) or str(x).strip() == "":
        return {}
    out = json.loads(str(x))
    if not isinstance(out, dict):
        raise RuntimeError(f"Expected JSON dict, got {x}")
    return out

def bool_series(s: pd.Series) -> pd.Series:
    if s.dtype == bool:
        return s
    return s.astype(str).str.lower().str.strip().map({"true": True, "false": False, "1": True, "0": False})

def safe_float(x: Any) -> float:
    return float("nan") if x is None or pd.isna(x) else float(x)

def json_dumps(x: Any) -> str:
    return json.dumps(x, ensure_ascii=False, sort_keys=True, default=str)

def load_random_seeds(path: Path) -> list[int]:
    # Modification Reason: 版本兼容; C01 is a simple YAML list, so parse seeds without
    # adding PyYAML as a required dependency.
    seeds = [int(x) for x in re.findall(r"\b20\d{6}\b", path.read_text(encoding="utf-8"))]
    if not seeds:
        raise RuntimeError(f"No seeds parsed from {path}")
    return seeds

def feature_hash() -> str:
    return hashlib.sha256("|".join(FEATURE_COLS).encode("utf-8")).hexdigest()

def check_files() -> None:
    required = [
        INPUT_PARQUET, INPUT_SPLIT, INPUT_MODEL_COMPARISON, INPUT_CV, INPUT_T09, INPUT_T10,
        INPUT_C01, INPUT_C02, INPUT_CONFUSION, INPUT_PCA_COORDS, INPUT_T11, INPUT_T12, INPUT_F05_DATA,
    ]
    missing = [str(p) for p in required if not p.exists()]
    if missing:
        raise FileNotFoundError("Missing Step 6 inputs:\n" + "\n".join(missing))

def validate_feature_whitelist(df: pd.DataFrame) -> None:
