def fail_if_missing_columns(df: pd.DataFrame, required_cols: Iterable[str], object_name: str) -> None:
    missing = [c for c in required_cols if c not in df.columns]
    if missing:
        raise RuntimeError(f"{object_name} is missing required columns: {', '.join(missing)}")

def parse_json_dict(value: Any) -> dict[str, Any]:
    if value is None or pd.isna(value) or str(value).strip() == "":
        return {}
    out = json.loads(str(value))
    if not isinstance(out, dict):
        raise RuntimeError("best_params_json must decode to dict.")
    return out

def safe_float(value: Any) -> float:
    if value is None or pd.isna(value):
        return float("nan")
    return float(value)

def sanitize_bool_series(s: pd.Series) -> pd.Series:
    if s.dtype == bool:
        return s
    return s.astype(str).str.lower().map({"true": True, "false": False, "1": True, "0": False})

