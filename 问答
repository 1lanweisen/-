# 3. Model factory
# Reference: Cho 2026 compared PCA-LDA, DT, RF, XGB, KNN, and SVM for ceramic chemical
# composition classification (DOI: 10.1038/s40494-026-02301-4).
# Reference: XGBoost official sklearn-estimator API:
# https://xgboost.readthedocs.io/en/latest/python/sklearn_estimator.html
# Modification Reason: 方案一致/泄漏防护; every model is wrapped in a scikit-learn Pipeline
# so scaling/PCA are fit only within training folds. Tree models include StandardScaler only
# to preserve one locked pipeline interface; linear scaling does not add target information.
# ======================================================================================

def make_base_pipeline(model_name: str, random_state: int) -> Pipeline:
    if model_name == "PCA_LDA":
        return Pipeline(
            steps=[
                ("scaler", StandardScaler()),
                ("pca", PCA(random_state=random_state)),
                ("clf", LinearDiscriminantAnalysis()),
            ]
        )
    if model_name == "DT":
        return Pipeline(
            steps=[
                ("scaler", StandardScaler()),
                ("clf", DecisionTreeClassifier(random_state=random_state)),
            ]
        )
    if model_name == "RF":
        return Pipeline(
            steps=[
                ("scaler", StandardScaler()),
                ("clf", RandomForestClassifier(random_state=random_state, n_jobs=N_JOBS_TREE)),
            ]
        )
    if model_name == "XGB":
        if XGBClassifier is None:
            raise RuntimeError(
                "xgboost is required for the locked XGB model but could not be imported. "
                f"Original import error: {repr(XGB_IMPORT_ERROR)}. Install it before running Step 4, e.g. pip install xgboost."
            )
        return Pipeline(
            steps=[
                ("scaler", StandardScaler()),
                (
                    "clf",
                    XGBClassifier(
                        objective="multi:softprob",
                        num_class=len(EXPECTED_CLASSES),
                        eval_metric="mlogloss",
                        random_state=random_state,
                        seed=random_state,
                        n_jobs=XGB_N_JOBS,
                        tree_method="hist",
                        verbosity=0,
                    ),
                ),
            ]
        )
    if model_name == "KNN":
        return Pipeline(
            steps=[
                ("scaler", StandardScaler()),
                ("clf", KNeighborsClassifier()),
            ]
        )
    if model_name == "SVM":
        return Pipeline(
            steps=[
                ("scaler", StandardScaler()),
                ("clf", SVC()),
            ]
        )
    raise ValueError(f"Unknown model_name: {model_name}")

