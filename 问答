def sha256_file(path: Path) -> str:
    """计算输入 parquet 的 SHA256，用于审计 Step 1 输出是否漂移。"""
    h = hashlib.sha256()
    with path.open("rb") as f:
        for chunk in iter(lambda: f.read(1024 * 1024), b""):
            h.update(chunk)
    return h.hexdigest()

def read_input_parquet(pd: Any, path: Path) -> Any:
    """
    读取 Step 1 parquet。

    Reference:
    https://pandas.pydata.org/docs/reference/api/pandas.read_parquet.html

    Modification Reason: 输入数据问题。Step 2 必须以 Step 1 的标准化 parquet 为唯一输入，
    不重新读取 Glazy 原始 CSV，避免重复执行 Surface/Cone 映射造成样本口径漂移。
    """
    if not path.exists():
        raise FileNotFoundError(f"未找到 Step 2 输入文件：{path}")
    if path.stat().st_size == 0:
        raise ValueError(f"Step 2 输入文件为空：{path}")
    return pd.read_parquet(path)

def write_csv(df: Any, path: Path) -> None:
    """
    写出 UTF-8 CSV 审计表。

    Reference:
    https://pandas.pydata.org/docs/reference/api/pandas.DataFrame.to_csv.html

    Modification Reason: 路径环境差异 / 跨环境兼容。固定 index=False 与 utf-8-sig，
    避免 pandas 默认索引被 RStudio/Excel 误读为分析字段，并降低 Windows 中文路径场景的乱码风险。
    """
    df.to_csv(
        path,
        index=False,
        encoding="utf-8-sig",
        quoting=csv.QUOTE_MINIMAL,
    )

def validate_input_contract(df: Any) -> None:
    """
    核验 Step 1 -> Step 2 输入合同。

    Reference: https://doi.org/10.48550/arXiv.2605.06641
    GlazyBench 在任务设置中强调标签分类体系、基础有效性检查和训练/测试互斥；
    本步骤先保证 Surface 标签、Cone 分层和九氧化物字段已按 Step 1 合同进入输入矩阵。

    Modification Reason: 输入数据问题。禁止在字段缺失时猜测字段名或自动寻找替代字段。
    """
    missing = [c for c in REQUIRED_INPUT_COLUMNS if c not in df.columns]
    if missing:
        raise ValueError("Step 2 必需字段缺失，禁止继续执行：{}".format(", ".join(missing)))

    if df.columns.duplicated().any():
        duplicated = df.columns[df.columns.duplicated()].tolist()
        raise ValueError(f"Step 2 输入存在重复列名，禁止继续：{duplicated}")

    invalid_surface = sorted(set(df["surface_type"].dropna().astype(str)) - ALLOWED_SURFACE_TYPES)
    if invalid_surface:
        raise ValueError(f"Step 2 输入含非 Matte/Satin/Glossy 标签，禁止继续：{invalid_surface}")

    if not bool(df["include_step1"].all()):
        bad = int((~df["include_step1"].astype(bool)).sum())
        raise ValueError(f"Step 2 输入含 include_step1=False 的记录，禁止继续。bad_rows={bad}")

def fixed_float_string(value: float, decimals: int) -> str:
    """生成稳定小数字符串，避免不同环境下浮点默认显示差异影响哈希。"""
    if value is None:
        return "NA"
    if isinstance(value, float) and (math.isnan(value) or math.isinf(value)):
        return "NA"
    return f"{float(value):.{decimals}f}"

def stable_sha256(text: str) -> str:
    """生成稳定 SHA256 字符串。"""
    return hashlib.sha256(text.encode("utf-8")).hexdigest()

def check_oxide_quality(pd: Any, df: Any) -> Any:
    """
    执行九核心氧化物硬性质控，并保留 Cho 96-104 wt% 规则为审计变量。

    Reference: https://doi.org/10.1038/s40494-026-02301-4
    Cho 2026 对完整十主要氧化物 XRF wt% 数据执行总氧化物 96-104 wt% 与缺失值筛除，
    随后归一化到 100 wt%。

    Modification Reason: 输入数据问题 / 字段不一致。
    改动前：Cho 2026 的 96-104 wt% 是完整十主要氧化物 XRF 闭合数据的硬剔除阈值。
    改动后：当前输入只有九个预锁定核心氧化物子组成，因此 96-104 wt% 只作为
    audit-only 标记，不用于剔除；硬剔除仅检查九氧化物缺失、负值、总和 <= 0。
    """
    out = df.copy()

    for oxide in CORE_OXIDES:
        out[f"{oxide}_raw"] = pd.to_numeric(out[oxide], errors="coerce")

    raw_cols = [f"{oxide}_raw" for oxide in CORE_OXIDES]

    out["core_oxide_missing_any"] = out[raw_cols].isna().any(axis=1)
    out["core_oxide_negative_any"] = (out[raw_cols] < 0).any(axis=1)
    out["oxide_sum_raw_9"] = out[raw_cols].sum(axis=1, min_count=len(CORE_OXIDES))
    out["oxide_sum_raw_9_nonpositive"] = (
        (~out["core_oxide_missing_any"]) & (out["oxide_sum_raw_9"] <= 0)
    )

    out["oxide_sum_raw_9_in_96_104_audit_only"] = out["oxide_sum_raw_9"].between(
        CHO_COMPLETE_OXIDE_SUM_LOWER,
        CHO_COMPLETE_OXIDE_SUM_UPPER,
        inclusive="both",
    )

    out["cho_96_104_not_used_for_exclusion_reason"] = (
        "Cho 2026 used complete ten-major-oxide XRF compositions for the 96-104 wt% "
        "exclusion rule; the current Step 1 input contains only the nine pre-locked "
        "target oxides, so the 96-104 flag is audit-only and is not used for exclusion."
    )

    reasons = []
    for idx in out.index:
        row_reasons = []
        if bool(out.at[idx, "core_oxide_missing_any"]):
            row_reasons.append("core_oxide_missing_or_non_numeric")
        if bool(out.at[idx, "core_oxide_negative_any"]):
            row_reasons.append("core_oxide_negative")
        if bool(out.at[idx, "oxide_sum_raw_9_nonpositive"]):
            row_reasons.append("oxide_sum_raw_9_nonpositive")
        reasons.append(";".join(row_reasons))

    out["oxide_qc_exclusion_reason"] = reasons
    out["include_step2_pre_duplicate"] = out["oxide_qc_exclusion_reason"].eq("")

    return out

def normalize_oxide_subcomposition(pd: Any, df: Any) -> Any:
    """
    将通过硬性质控的九核心氧化物子组成归一化到 100 wt%。

    Reference:
    https://doi.org/10.1038/s40494-026-02301-4
    https://doi.org/10.1146/annurev-statistics-042720-124436

    Modification Reason: 输入数据问题 / 其他。
    改动前：完整组成数据可按总氧化物接近 100 wt% 后归一化。
    改动后：当前只建模九个预锁定氧化物，归一化表示九变量子组成的相对比例；
    不声称九个氧化物构成完整釉料组成。
    """
    out = df.copy()
    pass_mask = out["include_step2_pre_duplicate"].astype(bool)

    for oxide in CORE_OXIDES:
        raw_col = f"{oxide}_raw"
        norm_col = f"{oxide}_norm100"
        out[norm_col] = pd.NA
        out.loc[pass_mask, norm_col] = (
            out.loc[pass_mask, raw_col] / out.loc[pass_mask, "oxide_sum_raw_9"] * 100.0
        ).astype(float)

    norm_cols = [f"{oxide}_norm100" for oxide in CORE_OXIDES]
    out["oxide_sum_norm_9"] = out[norm_cols].sum(axis=1, min_count=len(CORE_OXIDES))

    # Modification Reason: 字段不一致。后续方案统一读取 SiO2...ZnO 作为主分析字段；
    # 因此先把 Step 1 原始九氧化物保存在 *_raw，再用归一化后的九氧化物覆盖主分析字段。
    for oxide in CORE_OXIDES:
        out[oxide] = out[f"{oxide}_norm100"]

    return out

def make_exact_duplicate_key(row: Any) -> str:
    """
    构建严格重复判定键。

    Reference:
    https://github.com/derekphilipau/glazy-data
    https://github.com/PieterMostert/glazy-data-analysis

    Modification Reason: 泄漏防护 / 输入数据问题。
    改动前：原始 Glazy 可能存在重复或轻微变体；仅按 sample_id 无法识别组成重复。
    改动后：严格重复限定为 surface_type、cone_stratum 与九个归一化氧化物 1e-6
    固定格式完全一致；标签不同的近似组成不在此处静默合并，而由 composition_group_id
    在后续切分中统一隔离。
    """
    parts = [
        f"surface_type={row['surface_type']}",
        f"cone_stratum={row['cone_stratum']}",
    ]
    for oxide in CORE_OXIDES:
        parts.append(f"{oxide}={fixed_float_string(row[oxide], DEDUP_DECIMALS)}")
    return "|".join(parts)

def remove_exact_duplicates(pd: Any, df: Any) -> Any:
    """删除严格重复记录，并保留重复审计字段。"""
    out = df.copy()
    out["exact_duplicate_key"] = pd.NA
    pass_mask = out["include_step2_pre_duplicate"].astype(bool)

    out.loc[pass_mask, "exact_duplicate_key"] = out.loc[pass_mask].apply(
        make_exact_duplicate_key,
        axis=1,
    )

    sort_cols = []
    if "source_row_number" in out.columns:
        sort_cols.append("source_row_number")
    sort_cols.append("sample_id")

    working = out.loc[pass_mask].copy()
    working = working.sort_values(sort_cols, kind="mergesort")
    working["exact_duplicate_rank"] = working.groupby("exact_duplicate_key").cumcount() + 1
    working["exact_duplicate_group_size"] = working.groupby("exact_duplicate_key")[
        "exact_duplicate_key"
    ].transform("size")
    working["exact_duplicate_keep"] = working["exact_duplicate_rank"].eq(1)

    out["exact_duplicate_rank"] = pd.NA
    out["exact_duplicate_group_size"] = pd.NA
    out["exact_duplicate_keep"] = False

    out.loc[working.index, "exact_duplicate_rank"] = working["exact_duplicate_rank"]
    out.loc[working.index, "exact_duplicate_group_size"] = working["exact_duplicate_group_size"]
    out.loc[working.index, "exact_duplicate_keep"] = working["exact_duplicate_keep"]

    out["include_step2"] = out["include_step2_pre_duplicate"] & out["exact_duplicate_keep"]

    duplicate_excluded = out["include_step2_pre_duplicate"] & (~out["exact_duplicate_keep"])
    out.loc[duplicate_excluded, "oxide_qc_exclusion_reason"] = "exact_duplicate_removed"

    return out

def make_composition_group_fields(pd: Any, df: Any) -> Any:
    """
    生成 composition_group_id，用于后续 Step 4 泄漏防护。

    Reference:
    https://doi.org/10.48550/arXiv.2605.06641
    https://github.com/derekphilipau/glazy-data
    https://github.com/PieterMostert/glazy-data-analysis
    https://doi.org/10.1146/annurev-statistics-042720-124436

    Modification Reason: 泄漏防护。
    改动前：如果只按随机行切分，近重复 Glazy 配方可能同时进入训练集和测试集。
    改动后：九个归一化氧化物按 0.1 wt% 四舍五入，并与 cone_stratum 拼接后哈希；
    后续所有 split/CV 必须以该 group ID 为不可拆分单位。
    """
    out = df.copy()
    final_mask = out["include_step2"].astype(bool)

    out["composition_key_rounded_0p1"] = pd.NA
    out["composition_group_id"] = pd.NA

    def build_key(row: Any) -> str:
        parts = [f"cone_stratum={row['cone_stratum']}"]
        for oxide in CORE_OXIDES:
            rounded_value = round(float(row[oxide]), GROUP_ROUND_DECIMALS)
            parts.append(f"{oxide}={fixed_float_string(rounded_value, GROUP_ROUND_DECIMALS)}")
        return "|".join(parts)

    if final_mask.any():
        out.loc[final_mask, "composition_key_rounded_0p1"] = out.loc[final_mask].apply(
            build_key,
            axis=1,
        )
        out.loc[final_mask, "composition_group_id"] = out.loc[
            final_mask,
            "composition_key_rounded_0p1",
        ].map(stable_sha256)

        group_stats = (
            out.loc[final_mask]
            .groupby("composition_group_id", dropna=False)
            .agg(
                composition_group_size=("sample_id", "size"),
                composition_group_label_nunique=("surface_type", "nunique"),
                composition_group_label_set=(
                    "surface_type",
                    lambda x: "|".join(sorted(set(x.astype(str)))),
                ),
            )
            .reset_index()
        )

        out = out.merge(group_stats, on="composition_group_id", how="left")
    else:
        out["composition_group_size"] = pd.NA
        out["composition_group_label_nunique"] = pd.NA
        out["composition_group_label_set"] = pd.NA

    return out

def add_audit_metadata(df: Any, input_sha256: str) -> Any:
    """追加 Step 2 审计元数据。"""
    out = df.copy()
    now = datetime.now(timezone.utc).isoformat()

    out["step2_input_file"] = str(INPUT_PARQUET)
    out["step2_input_sha256"] = input_sha256
    out["step2_created_at_utc"] = now
    out["step2_rule_oxide_qc"] = (
        "hard exclusion: missing/non-numeric core oxide, negative core oxide, or "
        "oxide_sum_raw_9 <= 0; Cho 96-104 wt% is audit-only because current matrix "
        "is a nine-oxide subcomposition"
    )
    out["step2_rule_duplicate"] = (
        "exact duplicate = same surface_type + same cone_stratum + same normalized "
        "nine oxides formatted to 1e-6; keep earliest source_row_number/sample_id"
    )
    out["step2_rule_group_id"] = (
        "composition_group_id = sha256(cone_stratum + normalized nine oxides rounded "
        "to 0.1 wt%); used only for leakage protection"
    )
    return out

def build_t05_oxide_qc_summary(pd: Any, df_all: Any) -> Any:
    """
    构建氧化物质控审计表。

    Reference:
    https://doi.org/10.1038/s40494-026-02301-4

    Modification Reason: 输入数据问题。
    Cho 96-104 wt% 被保留为 audit-only 行，不进入 used_for_exclusion=True 的硬筛选规则。
    """
    rows = []

    def add_rule_rows(
        stage: str,
        qc_rule: str,
        fail_mask: Any,
        base_mask: Any,
        threshold_or_rule: str,
        used_for_exclusion: bool,
        reference: str,
        note: str,
    ) -> None:
        for surface in ["ALL", "Glossy", "Matte", "Satin"]:
            if surface == "ALL":
                m = base_mask
            else:
                m = base_mask & df_all["surface_type"].eq(surface)

            n_before = int(m.sum())
            n_failed = int((m & fail_mask).sum())
            n_passed = n_before - n_failed
            fail_rate = n_failed / n_before if n_before else 0.0
            rows.append(
                {
                    "stage": stage,
                    "qc_rule": qc_rule,
                    "surface_type": surface,
                    "n_before": n_before,
                    "n_failed": n_failed,
                    "n_passed": n_passed,
                    "fail_rate": fail_rate,
                    "threshold_or_rule": threshold_or_rule,
                    "used_for_exclusion": used_for_exclusion,
                    "reference": reference,
                    "note": note,
                }
            )

    all_mask = df_all.index == df_all.index
    add_rule_rows(
        stage="hard_qc",
        qc_rule="core_oxide_missing_or_non_numeric",
        fail_mask=df_all["core_oxide_missing_any"].astype(bool),
        base_mask=all_mask,
        threshold_or_rule="all nine core oxides must be numeric; zero is allowed",
        used_for_exclusion=True,
        reference=CHO_2026_DOI,
        note="Missing elemental values were excluded in Cho 2026; applied here to nine pre-locked core oxides.",
    )
    add_rule_rows(
        stage="hard_qc",
        qc_rule="core_oxide_negative",
        fail_mask=df_all["core_oxide_negative_any"].astype(bool),
        base_mask=all_mask,
        threshold_or_rule="oxide wt% must be >= 0",
        used_for_exclusion=True,
        reference=CHO_2026_DOI,
        note="Negative oxide percentages are chemically invalid for this wt% feature matrix.",
    )
    add_rule_rows(
        stage="hard_qc",
        qc_rule="oxide_sum_raw_9_nonpositive",
        fail_mask=df_all["oxide_sum_raw_9_nonpositive"].astype(bool),
        base_mask=all_mask,
        threshold_or_rule="sum of nine core oxides must be > 0",
        used_for_exclusion=True,
        reference=GREENACRE_2025_DOI,
        note="A positive denominator is required to close the nine-oxide subcomposition to 100 wt%.",
    )
    add_rule_rows(
        stage="audit_only",
        qc_rule="cho_complete_oxide_sum_96_104_audit_only_outside_range",
        fail_mask=~df_all["oxide_sum_raw_9_in_96_104_audit_only"].astype(bool),
        base_mask=~df_all["core_oxide_missing_any"].astype(bool),
        threshold_or_rule="96 <= oxide_sum_raw_9 <= 104, recorded but not used for exclusion",
        used_for_exclusion=False,
        reference=CHO_2026_DOI,
        note=(
            "Audit-only because Cho 2026 used complete ten-major-oxide XRF compositions, "
            "whereas current input is a nine-oxide subcomposition."
        ),
    )
    add_rule_rows(
        stage="duplicate_filter",
        qc_rule="exact_duplicate_removed",
        fail_mask=df_all["oxide_qc_exclusion_reason"].eq("exact_duplicate_removed"),
        base_mask=df_all["include_step2_pre_duplicate"].astype(bool),
        threshold_or_rule=(
            "same surface_type + cone_stratum + normalized nine oxides formatted to 1e-6"
        ),
        used_for_exclusion=True,
        reference=f"{GLAZY_DATA_URL}; {MOSTERT_GLAZY_ANALYSIS_URL}",
        note="Strict duplicates are removed before group ID creation; near duplicates are not removed here.",
    )

    return pd.DataFrame(rows)

def build_t06_duplicate_group_summary(pd: Any, df_all: Any, df_final: Any) -> Any:
    """
    构建重复与 composition_group_id 摘要表。

    Reference:
    https://doi.org/10.48550/arXiv.2605.06641
    https://github.com/derekphilipau/glazy-data
    https://github.com/PieterMostert/glazy-data-analysis

    Modification Reason: 泄漏防护。把重复删除与近重复分组分开审计，避免把
    composition_group_id 误解为真实来源谱系或因果簇。
    """
    rows = []

    pass_pre = df_all[df_all["include_step2_pre_duplicate"].astype(bool)].copy()
    exact_key_counts = pass_pre["exact_duplicate_key"].value_counts(dropna=False)
    rows.append(
        {
            "summary_level": "pre_duplicate_pass_rows",
            "key_type": "exact_duplicate_key",
            "n_rows": int(len(pass_pre)),
            "n_unique_keys": int(pass_pre["exact_duplicate_key"].nunique(dropna=False)),
            "n_duplicate_rows": int((~pass_pre["exact_duplicate_keep"].astype(bool)).sum()),
            "n_groups_size_gt1": int((exact_key_counts > 1).sum()),
            "n_label_conflict_groups": 0,
            "max_group_size": int(exact_key_counts.max()) if len(exact_key_counts) else 0,
            "reference": f"{GLAZY_DATA_URL}; {MOSTERT_GLAZY_ANALYSIS_URL}",
            "note": "Exact duplicates are same surface_type + cone_stratum + normalized nine oxides to 1e-6.",
        }
    )

    group_counts = df_final["composition_group_id"].value_counts(dropna=False)
    if len(df_final):
        label_conflicts = (
            df_final.groupby("composition_group_id")["surface_type"].nunique(dropna=False) > 1
        )
        n_label_conflict = int(label_conflicts.sum())
        max_group_size = int(group_counts.max())
    else:
        n_label_conflict = 0
        max_group_size = 0

    rows.append(
        {
            "summary_level": "final_retained_rows",
            "key_type": "composition_group_id",
            "n_rows": int(len(df_final)),
            "n_unique_keys": int(df_final["composition_group_id"].nunique(dropna=False)),
            "n_duplicate_rows": int(len(df_final) - df_final["composition_group_id"].nunique(dropna=False)),
            "n_groups_size_gt1": int((group_counts > 1).sum()),
            "n_label_conflict_groups": n_label_conflict,
            "max_group_size": max_group_size,
            "reference": f"{GLAZYBENCH_2026_DOI}; {GREENACRE_2025_DOI}",
            "note": (
                "Rounded 0.1 wt% nine-oxide subcomposition plus cone_stratum; "
                "used only to prevent train/test/CV leakage."
            ),
        }
    )

    for surface in ["Glossy", "Matte", "Satin"]:
        sdf = df_final[df_final["surface_type"].eq(surface)]
        counts = sdf["composition_group_id"].value_counts(dropna=False)
        rows.append(
            {
                "summary_level": f"final_retained_rows_{surface}",
                "key_type": "composition_group_id",
                "n_rows": int(len(sdf)),
                "n_unique_keys": int(sdf["composition_group_id"].nunique(dropna=False)),
                "n_duplicate_rows": int(len(sdf) - sdf["composition_group_id"].nunique(dropna=False)),
                "n_groups_size_gt1": int((counts > 1).sum()),
                "n_label_conflict_groups": "",
                "max_group_size": int(counts.max()) if len(counts) else 0,
                "reference": GLAZYBENCH_2026_DOI,
                "note": "Class-level group count for Step 3 sample-coverage gatekeeping.",
            }
        )

    return pd.DataFrame(rows)

